package main

// Test: Mixed single-line and multi-line ternary expressions
// Feature: Both styles should coexist in the same file
// Complexity: intermediate

func processMixed(a int, b int, c int) string {
	// Single-line ternaries (already supported)
	let max = a > b ? a : b
	let min = a < b ? a : b
	let abs = a < 0 ? -a : a

	// Multi-line ternaries
	let result1 = a > 50 ?
		"large" : "small"

	let result2 = b != 0 ? a :
		c

	let result3 = c == 0 ?
		a :
		b

	// Nested: outer multi-line, inner single-line
	let category = a > 100 ?
		(b > 50 ? "A" : "B") :
		(c > 25 ? "C" : "D")

	// Nested: outer single-line, inner multi-line
	let hybrid = a > 0 ? (b > 0 ? "both-positive" : "a-positive") : "a-negative"

	// Chained: mix of single and multi-line
	let grade = a >= 90 ? "A" :
		a >= 80 ? "B" :
		a >= 70 ?
			"C" :
			a >= 60 ? "D" : "F"

	// Complex expression with parentheses and newlines
	let computed = (a + b) > (c * 2) ?
		(a * b) + c :
		(a + b) * c

	// Multi-line ternary in function call
	println("Result:", a > 0 ?
		"positive" :
		"non-positive")

	// Single-line ternary in multi-line function call
	println(
		"Value:",
		a > b ? a : b,
		"Category:",
		category,
	)

	// Multi-line ternary with complex boolean expressions
	let access = (a > 10 && b > 20) || c > 30 ?
		"granted" :
		"denied"

	// Chained with mixed operators
	let final = a != 0 ?
		a :
		b != 0 ? b :
		c != 0 ?
			c :
			42

	return final
}

func main() {
	let result = processMixed(15, 25, 35)
	println("Final:", result)
}
