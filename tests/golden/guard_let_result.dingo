// Test: Guard Let with Result type (interface-based enum)
// Feature: Guard let unwrapping custom Result enum
// Complexity: intermediate
package main

import (
	"errors"
	"fmt"
)

enum Result {
	Ok(string),
	Err(error),
}

func FindUser(id int) Result {
	if id > 0 {
		return NewResultOk(fmt.Sprintf("User%d", id))
	}
	return NewResultErr(errors.New("user not found"))
}

func FindOrder(userID int) Result {
	if userID == 1 {
		return NewResultOk("Order123")
	}
	return NewResultErr(errors.New("order not found"))
}

// Basic guard let with Result
func GetUserOrder(userID int) Result {
	let userResult = FindUser(userID)
	guard let user = userResult else |err| {
		return err
	}

	let orderResult = FindOrder(userID)
	guard let order = orderResult else |err| {
		return err
	}

	return NewResultOk(fmt.Sprintf("%s has %s", user, order))
}

// Multiple guard lets in sequence
func ProcessUserOrders(userID int) Result {
	guard let user = FindUser(userID) else |err| {
		return err
	}

	guard let order = FindOrder(userID) else |err| {
		return err
	}

	fmt.Printf("Processing: %s, %s\n", user, order)
	return NewResultOk("success")
}

// Custom error handling in else block
func GetUserWithLogging(userID int) Result {
	guard let user = FindUser(userID) else |err| {
		fmt.Printf("Failed to find user %d: %v\n", userID, err)
		return NewResultErr(fmt.Errorf("user lookup failed: %w", err))
	}

	fmt.Printf("Found user: %s\n", user)
	return NewResultOk(user)
}

func main() {
	let result = GetUserOrder(1)
	switch v := result.(type) {
	case ResultOk:
		fmt.Println(v.Value)
	}

	let result2 = ProcessUserOrders(1)
	switch v := result2.(type) {
	case ResultOk:
		fmt.Println(v.Value)
	}

	let result3 = GetUserWithLogging(0)
	switch v := result3.(type) {
	case ResultErr:
		fmt.Println("Error:", v.Value)
	}
}
