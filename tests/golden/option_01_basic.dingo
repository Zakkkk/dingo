// Test: Basic Option[T] usage with generic types
// Feature: Option type via dgo package
// Complexity: basic
package main

func findUser(id int) Option[string] {
	if id > 0 {
		return Some("User" + string(rune(id)))
	}
	return None[string]()
}

func main() {
	result := findUser(42)
	if result.IsSome() {
		println("Found:", result.MustSome())
	} else {
		println("Not found")
	}
}
