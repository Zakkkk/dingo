package main

import "fmt"

func main() {
	// Currying with explicit types
	let typedAdd = (x: int) => (y: int) => x + y
	let typedAdd10 = typedAdd(10)

	// Mixed: outer typed, inner inferred
	let partialTyped = (x: int) => (y) => x + y

	// In higher-order function
	let applyTwice = (f) => (x) => f(f(x))
	let add1 = (n: int) => n + 1
	let add2 = applyTwice(add1)

	fmt.Println("typedAdd(10)(5) =", typedAdd10(5))
	fmt.Println("partialTyped(3)(7) =", partialTyped(3)(7))
	fmt.Println("applyTwice(add1)(0) =", add2(0))
}
