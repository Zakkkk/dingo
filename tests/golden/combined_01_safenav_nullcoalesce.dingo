package main

// Test: Combined safe navigation and null coalescing edge cases
// Feature: Safe navigation (?.) + Null coalescing (??)
// Complexity: medium
// Description: Tests edge cases beyond safe_nav_08_combined including:
// - Method chains with null coalesce fallbacks
// - Nested safe nav with multiple levels of defaults
// - Expression-level combinations

import "fmt"

enum StringOption {
	Some(string),
	None,
}

enum IntOption {
	Some(int),
	None,
}

enum BoolOption {
	Some(bool),
	None,
}

type User struct {
	name     string
	settings *Settings
	metadata *Metadata
}

type Settings struct {
	theme      *string
	language   *string
	prefs      *Preferences
}

type Preferences struct {
	notifications *bool
	autoSave      *bool
	timeout       *int
}

type Metadata struct {
	tags   []string
	labels map[string]string
}

func main() {
	// ===== Test 1: Method Chains with Null Coalesce =====
	// Scenario: Chain method calls, fallback on nil
	let user1 = getUser(1)

	// Method chain: getValue()?.process() ?? backup()
	let processed = user1?.settings?.getThemeName() ?? getDefaultTheme()
	fmt.Println("Processed theme:", processed)

	// Method with args: user?.transform("upper") ?? default
	let transformed = user1?.settings?.transform("uppercase") ?? "FALLBACK"
	fmt.Println("Transformed:", transformed)

	// ===== Test 2: Nested Safe Nav with Multiple Defaults =====
	// Scenario: Deep nesting with fallbacks at each level
	let user2 = getUser(2)

	// Three levels deep: a?.b?.c ?? d?.e ?? f
	let timeout1 = user2?.settings?.prefs?.timeout ?? user1?.settings?.prefs?.timeout ?? 30
	fmt.Println("Timeout 1:", timeout1)

	// Alternate fallback chain: a?.b ?? c?.d ?? literal
	let lang = user2?.settings?.language ?? user1?.settings?.language ?? "en"
	fmt.Println("Language:", lang)

	// ===== Test 3: Safe Nav in Expressions with Null Coalesce =====
	// Scenario: Use safe nav results in larger expressions
	let user3 = getUser(3)

	// Arithmetic: (a?.b ?? 10) + (c?.d ?? 20)
	let sum = (user3?.settings?.prefs?.timeout ?? 10) + (user1?.settings?.prefs?.timeout ?? 20)
	fmt.Println("Sum:", sum)

	// String concatenation: (a?.b ?? "x") + (c?.d ?? "y")
	let combined = (user3?.settings?.theme ?? "dark") + "-" + (user3?.settings?.language ?? "en")
	fmt.Println("Combined:", combined)

	// Boolean logic: (a?.b ?? true) && (c?.d ?? false)
	let enabled = (user3?.settings?.prefs?.notifications ?? true) && (user3?.settings?.prefs?.autoSave ?? false)
	fmt.Println("Enabled:", enabled)

	// ===== Test 4: Null Coalesce with Function Call Fallbacks =====
	// Scenario: Use function calls as fallback values
	let user4 = getUser(4)

	// Function call fallback: a?.b ?? computeValue()
	let theme1 = user4?.settings?.theme ?? computeDefaultTheme()
	fmt.Println("Theme 1:", theme1)

	// Chained function fallbacks: a?.b ?? f1() ?? f2()
	let theme2 = user4?.settings?.theme ?? getUserTheme(user4) ?? getSystemTheme()
	fmt.Println("Theme 2:", theme2)

	// ===== Test 5: Safe Nav on Method Return Values =====
	// Scenario: Chain methods that return pointers
	let user5 = getUser(5)

	// Method returning pointer: user.getSettings()?.theme
	let theme3 = user5.getSettings()?.theme ?? "default"
	fmt.Println("Theme 3:", theme3)

	// Chained method calls: user.get()?.process()?.value
	let value = user5.getSettings()?.getPreferences()?.timeout ?? 60
	fmt.Println("Value:", value)

	// ===== Test 6: Parenthesized Safe Nav with Null Coalesce =====
	// Scenario: Complex grouping and precedence
	let user6 = getUser(6)

	// Grouped safe nav: (a?.b)?.c ?? d
	let notif1 = (user6?.settings)?.prefs?.notifications ?? true
	fmt.Println("Notifications 1:", notif1)

	// Multiple groups: (a?.b ?? c) + (d?.e ?? f)
	let timeoutSum = (user6?.settings?.prefs?.timeout ?? 30) + (user1?.settings?.prefs?.timeout ?? 10)
	fmt.Println("Timeout sum:", timeoutSum)
}

// ===== Helper Functions =====

func getUser(id int) *User {
	if id == 1 {
		let theme = "light"
		let lang = "en"
		let timeout = 30
		let autoSave = true
		return &User{
			name: "Alice",
			settings: &Settings{
				theme:    &theme,
				language: &lang,
				prefs: &Preferences{
					timeout:  &timeout,
					autoSave: &autoSave,
				},
			},
		}
	}
	return nil
}

func getDefaultTheme() string {
	return "system-default"
}

func computeDefaultTheme() string {
	return "computed-theme"
}

func getUserTheme(user *User) *string {
	return nil
}

func getSystemTheme() string {
	return "system-theme"
}

// Settings methods
func (s *Settings) getThemeName() StringOption {
	if s != nil && s.theme != nil {
		return StringOptionSome(*s.theme)
	}
	let none = StringOption{}
	return none
}

func (s *Settings) transform(mode string) StringOption {
	if s != nil && s.theme != nil {
		return StringOptionSome(*s.theme + "-transformed")
	}
	let none = StringOption{}
	return none
}

func (s *Settings) getPreferences() *Preferences {
	if s != nil {
		return s.prefs
	}
	return nil
}

// User methods
func (u *User) getSettings() *Settings {
	if u != nil {
		return u.settings
	}
	return nil
}
