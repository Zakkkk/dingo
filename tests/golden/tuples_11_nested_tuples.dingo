package main

// Test: Nested tuple literals
// Feature: Tuples containing other tuples as elements
// Complexity: advanced

func getNestedPair() ((int, int), int) {
	return ((10, 20), 30)
}

func getDeepNested() (((int, int), int), int) {
	return (((1, 2), 3), 4)
}

func getComplexNested() ((string, int), (bool, float64)) {
	return (("hello", 42), (true, 3.14))
}

func main() {
	// Simple nested tuple: pair within pair
	let nested1 = ((1, 2), 3)
	println("Nested 1:", nested1)

	// Access nested tuple as a whole
	let pair = (10, 20)
	let outer = (pair, 30)
	println("Outer:", outer)

	// Multiple levels of nesting
	let deep = (((100, 200), 300), 400)
	println("Deep nested:", deep)

	// Mixed types in nested tuples
	let mixed = (("name", 25), (true, 3.14))
	println("Mixed types:", mixed)

	// Nested tuples with different shapes
	let asymmetric = ((1, 2, 3), (4, 5))
	println("Asymmetric:", asymmetric)

	// Function returning nested tuple
	let result1 = getNestedPair()
	println("From function:", result1)

	// Deeply nested from function
	let result2 = getDeepNested()
	println("Deep from function:", result2)

	// Complex nested from function
	let result3 = getComplexNested()
	println("Complex from function:", result3)

	// Nested tuple as parameter (via variable)
	let data = ((7, 8), 9)
	processNested(data)

	// Edge case: tuple containing single-element wrapper
	// (In real use, this would be ((x,), y) but Go doesn't have single tuples)
	let wrapped = ((10, 11), 12)
	println("Wrapped:", wrapped)
}

func processNested(data ((int, int), int)) {
	println("Processing nested:", data)
}
