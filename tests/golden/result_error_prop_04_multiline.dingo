package main

import "database/sql"

// Custom error type for multiline testing
type ServiceError struct {
	Code    string
	Message string
	Context string
}

func (e ServiceError) Error() string {
	return e.Code + ": " + e.Message + " (" + e.Context + ")"
}

// Test multiple error propagations in sequence (not multiline literal)
func QueryOrders(db *sql.DB) Result[[]string, ServiceError] {
	let rows = db.Query("SELECT * FROM orders")? ServiceError{Code: "DB_ERROR", Message: err.Error(), Context: "QueryOrders"}
	defer rows.Close()

	// Second error propagation
	let data = db.Query("SELECT * FROM data")? ServiceError{Code: "QUERY_ERROR", Message: err.Error(), Context: "data query"}
	defer data.Close()

	return ResultSliceStringServiceErrorOk([]string{"order1"})
}

func main() {
	let db: *sql.DB = nil
	let result = QueryOrders(db)
	if result.IsErr() {
		println("Error:", result.err.Error())
	}
}
