package main

import "database/sql"

// Custom error type with struct literal syntax
type ServiceError struct {
	Code    string
	Message string
}

func (e ServiceError) Error() string {
	return e.Code + ": " + e.Message
}

// Test basic struct literal with err.Error()
func FindOrders(db *sql.DB) Result<[]string, ServiceError> {
	let rows = db.Query("SELECT * FROM orders")? ServiceError{Code: "DB_ERROR", Message: err.Error()}
	defer rows.Close()
	return ResultSliceStringServiceErrorOk([]string{"order1", "order2"})
}

func main() {
	let db: *sql.DB = nil
	let result = FindOrders(db)
	if result.IsErr() {
		println("Error:", result.err.Error())
	}
}
