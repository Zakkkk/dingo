package main

import (
	"database/sql"
	"io"
	"github.com/MadAppGang/dingo/pkg/dgo"
)

// Custom error type demonstrating all patterns
type AppError struct {
	Code    string
	Message string
}

func (e AppError) Error() string {
	return e.Code + ": " + e.Message
}
func (AppError) NewDBError(err error) AppError {
	return AppError{Code: "DB_ERROR", Message: err.Error()}
}
func WrapIOError(err error) AppError {
	return AppError{Code: "IO_ERROR", Message: err.Error()}
}

// Test mixing all three patterns in one function
func ProcessData(db *sql.DB, reader io.Reader) dgo.Result[string, AppError] {
	// Pattern 1: Struct literal
	tmp, err := db.Query("SELECT * FROM data")

	if err != nil {
		return ResultStringAppErrorErr(AppError{Code: "DB_ERROR", Message: err.Error()})
	}
	var rows = tmp
	defer rows.Close()

	// Pattern 2: Method call
	tmp1, err1 := db.Conn(nil)

	if err1 != nil {
		return ResultStringAppErrorErr(AppError.NewDBError(err))
	}
	var conn = tmp1
	defer conn.Close()

	// Pattern 3: Function call
	buf := make([]byte, 100)
	tmp2, err2 := reader.Read(buf)

	if err2 != nil {
		return ResultStringAppErrorErr(WrapIOError(err))
	}
	var n = tmp2

	return ResultStringAppErrorOk("success")
}
func main() {
	var db *sql.DB = nil
	var reader io.Reader = nil
	result := ProcessData(db, reader)
	if result.IsErr() {
		println("Error:", result.err.Error())
	}
}
