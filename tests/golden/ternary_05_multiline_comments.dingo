package main

// Test: Multi-line ternary with inline comments
// Feature: Ternary operator with comments between parts
// Complexity: intermediate

func processValue(condition bool, a string, b string) string {
	// Case 1: Comment after ? on same line
	let result1 = condition ? // when true
		a : b

	// Case 2: Comment after : on same line
	let result2 = condition ? a : // when false
		b

	// Case 3: Comments after both ? and :
	let result3 = condition ? // true branch
		a : // false branch
		b

	// Case 4: Multiple newlines after ?
	let result4 = condition ?


		a : b

	// Case 5: Multiple newlines after :
	let result5 = condition ? a :


		b

	// Case 6: Chained ternary with comments
	let priority = ""
	let fallback = a != "" ? a : // first fallback
		b != "" ? b : // second fallback
		priority != "" ? priority : // third fallback
		"default" // ultimate default

	// Case 7: Complex expression with mixed newlines and comments
	let isValid = true
	let hasPermission = false
	let access = isValid ? // check validity
		hasPermission ? // check permission
			"full-access" : // has permission
			"read-only" : // not valid
		"no-access"

	// Case 8: Ternary spanning many lines with complex conditions
	let config = getConfig()
	let endpoint = (config?.Host ?? "") != "" && config?.Port ?? 0 > 0 ?
		config?.Host ?? "" + ":" + string(config?.Port ?? 0) :
		(config?.Host ?? "") != "" ?
			config?.Host ?? "" + ":8080" :
			"localhost:8080"

	return fallback
}

func getConfig() *Config {
	return &Config{Host: "example.com", Port: 3000}
}

type Config struct {
	Host string
	Port int
}

func main() {
	let result = processValue(true, "first", "second")
	println("Result:", result)
}
