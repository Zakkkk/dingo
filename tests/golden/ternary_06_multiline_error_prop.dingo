package main

// Test: Multi-line ternary with error propagation
// Feature: Ensure error propagation (?) still works with newlines
// Complexity: intermediate

func getData() Result[string] {
	return Ok("data")
}

func getConfig() Result[*Config] {
	return Ok(&Config{Host: "example.com"})
}

func processData() Result[string] {
	// Case 1: Error propagation with newline should still be error propagation
	let data = getData()?
	let moreData = getData()?

	// Case 2: Ternary with newline vs error propagation with newline
	let config = getConfig()?
	let host1 = config.Host != "" ?
		config.Host :
		"localhost"

	// Case 3: Error propagation in ternary condition
	let result = getData()? != "" ? getData()? : "default"

	// Case 4: Mixed error propagation and multi-line ternary
	let value = getData()?
	let processed = value != "" ?
		value + "-processed" :
		getData()? + "-fallback"

	// Case 5: Error propagation with comment and newline
	let raw = getData()? // get the data

	// Case 6: Multi-line ternary with error propagation in branches
	let final = config.Host != "" ?
		getData()? :
		"default"

	return Ok(final)
}

type Config struct {
	Host string
}

func main() {
	let result = processData()
	match result {
		Ok(val) => println("Success:", val)
		Err(e) => println("Error:", e)
	}
}
