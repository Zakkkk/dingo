package main

type Config struct {
	Region *string
}

// Test: ternary with len(safe_nav) in return context
func GetRegion(c *Config) string {
	return len(c?.Region) > 0 ? *c.Region : "us-east-1"
}

// Test: ternary with len(safe_nav) in local variable context
func TestNilConfig() string {
	var c *Config = nil
	return len(c?.Region) > 0 ? "has" : "none"
}
