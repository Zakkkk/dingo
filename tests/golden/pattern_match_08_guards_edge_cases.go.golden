package main

// Test: Guard edge cases - all arms guarded, wildcard with guard, performance
// Feature: Edge cases for pattern guard behavior
// Complexity: advanced

type Value interface {
	isValue()
	IsSmall() bool
	IsMedium() bool
	IsLarge() bool
}

type ValueSmall struct{ Value int }

func (ValueSmall) isValue()         {}
func NewValueSmall(value int) Value { return ValueSmall{Value: value} }

type ValueMedium struct{ Value int }

func (ValueMedium) isValue()         {}
func NewValueMedium(value int) Value { return ValueMedium{Value: value} }

type ValueLarge struct{ Value int }

func (ValueLarge) isValue()         {}
func NewValueLarge(value int) Value { return ValueLarge{Value: value} }

func IsValueSmall(v Value) bool    { _, ok := v.(ValueSmall); return ok }
func IsValueMedium(v Value) bool   { _, ok := v.(ValueMedium); return ok }
func IsValueLarge(v Value) bool    { _, ok := v.(ValueLarge); return ok }
func (ValueSmall) IsSmall() bool   { return true }
func (ValueSmall) IsMedium() bool  { return false }
func (ValueSmall) IsLarge() bool   { return false }
func (ValueMedium) IsSmall() bool  { return false }
func (ValueMedium) IsMedium() bool { return true }
func (ValueMedium) IsLarge() bool  { return false }
func (ValueLarge) IsSmall() bool   { return false }
func (ValueLarge) IsMedium() bool  { return false }
func (ValueLarge) IsLarge() bool   { return true }

// All patterns have guards (requires fallback wildcard)
func classify(val Value) string {
	return func() string {
		switch v := val.(type) {
		case Value_Small:
			x := v.x
			if x > 10 {
				return "actually medium"
			}
			panic("match guard failed without fallback")
		case Value_Medium:
			x := v.x
			if x > 100 {
				return "actually large"
			}
			panic("match guard failed without fallback")
		case Value_Large:
			x := v.x
			if x > 1000 {
				return "actually huge"
			}
			panic("match guard failed without fallback")
		default:
			return "normal range"
		}
	}()
}

// Wildcard pattern with guard
func filterPositive(val Value) string {
	return func() string {
		switch v := val.(type) {
		case Value_Small:
			x := v.x
			if x > 0 {
				return "positive small"
			}
			panic("match guard failed without fallback")
		case Value_Medium:
			x := v.x
			if x > 0 {
				return "positive medium"
			}
			panic("match guard failed without fallback")
		case Value_Large:
			x := v.x
			if x > 0 {
				return "positive large"
			}
			panic("match guard failed without fallback")
		default:
			if true {
				return "non-positive or zero"
			}
			panic("match guard failed without fallback")
		}
	}()
}

// Many guarded arms (performance test)
func granularClassify(val Value) string {
	return func() string {
		switch v := val.(type) {
		case Value_Small:
			x := v.x
			if x == 1 {
				return "one"
			}
			panic("match guard failed without fallback")
		case Value_Small:
			x := v.x
			if x == 2 {
				return "two"
			}
			panic("match guard failed without fallback")
		case Value_Small:
			x := v.x
			if x == 3 {
				return "three"
			}
			panic("match guard failed without fallback")
		case Value_Small:
			x := v.x
			if x == 4 {
				return "four"
			}
			panic("match guard failed without fallback")
		case Value_Small:
			x := v.x
			if x == 5 {
				return "five"
			}
			panic("match guard failed without fallback")
		case Value_Small:
			x := v.x
			if x > 5 && x < 10 {
				return "five to ten"
			}
			panic("match guard failed without fallback")
		case Value_Small:
			return "small other"
		case Value_Medium:
			x := v.x
			if x < 50 {
				return "lower medium"
			}
			panic("match guard failed without fallback")
		case Value_Medium:
			x := v.x
			if x >= 50 && x < 100 {
				return "mid medium"
			}
			panic("match guard failed without fallback")
		case Value_Medium:
			return "upper medium"
		case Value_Large:
			return "large"
		}
	}()
}

// Guard with constant condition (optimization test)
func alwaysMatch(val Value) string {
	return func() string {
		switch v := val.(type) {
		case Value_Small:
			if true {
				return "small"
			}
			panic("match guard failed without fallback")
		case Value_Medium:
			if 1 > 0 {
				return "medium"
			}
			panic("match guard failed without fallback")
		case Value_Large:
			return "large"
		}
	}()
}

// Guard with side effects (not recommended but valid)
func countMatches(val Value) string {
	var count int = 0
	return func() string {
		switch v := val.(type) {
		case Value_Small:
			x := v.x
			if increment(&count) && x > 0 {
				return "small positive"
			}
			panic("match guard failed without fallback")
		case Value_Medium:
			x := v.x
			if increment(&count) && x > 0 {
				return "medium positive"
			}
			panic("match guard failed without fallback")
		case Value_Large:
			x := v.x
			if increment(&count) && x > 0 {
				return "large positive"
			}
			panic("match guard failed without fallback")
		default:
			return "other"
		}
	}()
}

func increment(p *int) bool {
	*p++
	return true
}

func main() {
	println(classify(Value_Small(15)))
	println(filterPositive(Value_Medium(-5)))
	println(granularClassify(Value_Small(3)))
	println(alwaysMatch(Value_Medium(42)))
}
