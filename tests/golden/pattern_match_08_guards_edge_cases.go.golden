package main

// Test: Guard edge cases - all arms guarded, wildcard with guard, performance
// Feature: Edge cases for pattern guard behavior
// Complexity: advanced

// dingo:n:0
type ValueTag uint8

const (
	ValueTagSmall ValueTag = iota
	ValueTagMedium
	ValueTagLarge
)

type Value struct {
	tag    ValueTag
	large  *int
	medium *int
	small  *int
}

func ValueSmall(arg0 int) Value {
	return Value{tag: ValueTagSmall, small: &arg0}
}
func ValueMedium(arg0 int) Value {
	return Value{tag: ValueTagMedium, medium: &arg0}
}
func ValueLarge(arg0 int) Value {
	return Value{tag: ValueTagLarge, large: &arg0}
}
func (e Value) IsSmall() bool {
	return e.tag == ValueTagSmall
}
func (e Value) IsMedium() bool {
	return e.tag == ValueTagMedium
}
func (e Value) IsLarge() bool {
	return e.tag == ValueTagLarge
}

// All patterns have guards (requires fallback wildcard)
func classify(val Value) string {
	var __match_result_0 string
	// DINGO_MATCH_START: val
	scrutinee := val
	switch scrutinee.tag {
	case ValueTagSmall:
		x := *scrutinee.small
		// DINGO_PATTERN: ValueSmall(x) | DINGO_GUARD: x > 10
		if x > 10 {
			__match_result_0 = "actually medium"
		}
	case ValueTagMedium:
		x := *scrutinee.medium
		// DINGO_PATTERN: ValueMedium(x) | DINGO_GUARD: x > 100
		if x > 100 {
			__match_result_0 = "actually large"
		}
	case ValueTagLarge:
		x := *scrutinee.large
		// DINGO_PATTERN: ValueLarge(x) | DINGO_GUARD: x > 1000
		if x > 1000 {
			__match_result_0 = "actually huge"
		}
	default:
		// DINGO_PATTERN: _
		__match_result_0 = "normal range"
	}
	return __match_result_0
	// DINGO_MATCH_END

}

// Wildcard pattern with guard
func filterPositive(val Value) string {
	var __match_result_1 string
	// DINGO_MATCH_START: val
	scrutinee2 := val
	switch scrutinee2.tag {
	case ValueTagSmall:
		x := *scrutinee2.small
		// DINGO_PATTERN: ValueSmall(x) | DINGO_GUARD: x > 0
		if x > 0 {
			__match_result_1 = "positive small"
		}
	case ValueTagMedium:
		x := *scrutinee2.medium
		// DINGO_PATTERN: ValueMedium(x) | DINGO_GUARD: x > 0
		if x > 0 {
			__match_result_1 = "positive medium"
		}
	case ValueTagLarge:
		x := *scrutinee2.large
		// DINGO_PATTERN: ValueLarge(x) | DINGO_GUARD: x > 0
		if x > 0 {
			__match_result_1 = "positive large"
		}
	default:
		// DINGO_PATTERN: _
		__match_result_1 = "non-positive or zero"
	}
	return __match_result_1
	// DINGO_MATCH_END

}

// Many guarded arms (performance test)
func granularClassify(val Value) string {
	var __match_result_2 string
	// DINGO_MATCH_START: val
	scrutinee3 := val
	switch scrutinee3.tag {
	case ValueTagSmall:
		x := *scrutinee3.small
		// DINGO_PATTERN: ValueSmall(x) | DINGO_GUARD: x == 1
		if x == 1 {
			__match_result_2 = "one"
			// DINGO_PATTERN: ValueSmall(x) | DINGO_GUARD: x == 2
		} else if x == 2 {
			__match_result_2 = "two"
			// DINGO_PATTERN: ValueSmall(x) | DINGO_GUARD: x == 3
		} else if x == 3 {
			__match_result_2 = "three"
			// DINGO_PATTERN: ValueSmall(x) | DINGO_GUARD: x == 4
		} else if x == 4 {
			__match_result_2 = "four"
			// DINGO_PATTERN: ValueSmall(x) | DINGO_GUARD: x == 5
		} else if x == 5 {
			__match_result_2 = "five"
			// DINGO_PATTERN: ValueSmall(x) | DINGO_GUARD: x > 5 && x < 10
		} else if x > 5 && x < 10 {
			__match_result_2 = "five to ten"
			// DINGO_PATTERN: ValueSmall(_)
		} else {
			__match_result_2 = "small other"
		}
	case ValueTagMedium:
		x := *scrutinee3.medium
		// DINGO_PATTERN: ValueMedium(x) | DINGO_GUARD: x < 50
		if x < 50 {
			__match_result_2 = "lower medium"
			// DINGO_PATTERN: ValueMedium(x) | DINGO_GUARD: x >= 50 && x < 100
		} else if x >= 50 && x < 100 {
			__match_result_2 = "mid medium"
			// DINGO_PATTERN: ValueMedium(_)
		} else {
			__match_result_2 = "upper medium"
		}
	case ValueTagLarge:
		// DINGO_PATTERN: ValueLarge(_)
		__match_result_2 = "large"
	}
	return __match_result_2
	// DINGO_MATCH_END

}

// Guard with constant condition (optimization test)
func alwaysMatch(val Value) string {
	var __match_result_3 string
	// DINGO_MATCH_START: val
	scrutinee4 := val
	switch scrutinee4.tag {
	case ValueTagSmall:
		// DINGO_PATTERN: ValueSmall(_) | DINGO_GUARD: true
		if true {
			__match_result_3 = "small"
		}
	case ValueTagMedium:
		// DINGO_PATTERN: ValueMedium(_) | DINGO_GUARD: 1 > 0
		if 1 > 0 {
			__match_result_3 = "medium"
		}
	case ValueTagLarge:
		// DINGO_PATTERN: ValueLarge(_)
		__match_result_3 = "large"
	}
	return __match_result_3
	// DINGO_MATCH_END

}

// Guard with side effects (not recommended but valid)
func countMatches(val Value) string {
	var count int = 0
	var __match_result_4 string
	// DINGO_MATCH_START: val
	scrutinee5 := val
	switch scrutinee5.tag {
	case ValueTagSmall:
		x := *scrutinee5.small
		// DINGO_PATTERN: ValueSmall(x) | DINGO_GUARD: increment(&count) && x > 0
		if increment(&count) && x > 0 {
			__match_result_4 = "small positive"
		}
	case ValueTagMedium:
		x := *scrutinee5.medium
		// DINGO_PATTERN: ValueMedium(x) | DINGO_GUARD: increment(&count) && x > 0
		if increment(&count) && x > 0 {
			__match_result_4 = "medium positive"
		}
	case ValueTagLarge:
		x := *scrutinee5.large
		// DINGO_PATTERN: ValueLarge(x) | DINGO_GUARD: increment(&count) && x > 0
		if increment(&count) && x > 0 {
			__match_result_4 = "large positive"
		}
	default:
		// DINGO_PATTERN: _
		__match_result_4 = "other"
	}
	return __match_result_4
	// DINGO_MATCH_END

}
func increment(p *int) bool {
	*p++
	return true
}
func main() {
	println(classify(ValueSmall(15)))
	println(filterPositive(ValueMedium(-5)))
	println(granularClassify(ValueSmall(3)))
	println(alwaysMatch(ValueMedium(42)))
}
