package main

// Test: Multiline lambda expressions
// Feature: Lambdas with block syntax
// Complexity: intermediate

func main() {
	// Multiline lambda with block
	process := func(x int, y int) int {
		sum := x + y
		doubled := sum * 2
		return doubled
	}

	// Lambda with conditional
	max := func(a int, b int) int {
		if a > b {
			return a
		}
		return b
	}

	result := process(5, 3)
	maxVal := max(10, 20)
	println("Result:", result, "Max:", maxVal)
}
