// Test: Option[T] helper methods
// Feature: SomeOrElse, Map, AndThen, Filter
// Complexity: advanced
package main

import "fmt"

// Configuration struct
type Config struct {
	Port    int
	Verbose bool
}

// getPort returns an optional port value
func getPort() Option[int] {
	// Simulate reading from environment - might fail
	return Some(8080)
}

// getVerboseFlag returns an optional verbose flag
func getVerboseFlag() Option[bool] {
	return None[bool]()
}

// parseConfig builds a Config from optional values
func parseConfig() Config {
	// SomeOrElse: Use default value from function if None
	let port = getPort().SomeOrElse(|| 3000)

	// SomeOr: Use default value directly
	let verbose = getVerboseFlag().SomeOr(false)

	return Config{Port: port, Verbose: verbose}
}

// processPort demonstrates Map transformation
func processPort(opt Option[int]) Option[int] {
	// Map: Transform Some value, propagate None
	return opt.Map(|port| port * 2)
}

// validatePort demonstrates Filter
func validatePort(opt Option[int]) Option[int] {
	// Filter: Keep Some values that pass predicate
	return opt.Filter(|port| port > 1024 && port < 65535)
}

// getValidPort demonstrates AndThen chaining
func getValidPort(id int) Option[int] {
	return getPort().AndThen(|port| {
		// Chain operation: validate and adjust
		if port < 1024 {
			return None[int]()
		}
		return Some(port + id)
	})
}

// Complex chaining example
func processConfig(useDefault bool) Option[int] {
	let port = getPort()

	// Chain multiple operations
	let result = port.
		Map(|p| p + 1000).
		Filter(|p| p < 10000).
		AndThen(|p| {
			if p % 2 == 0 {
				return Some(p / 2)
			}
			return None[int]()
		})

	if result.IsNone() && useDefault {
		return Some(3000)
	}

	return result
}

func main() {
	// Test SomeOrElse
	let cfg = parseConfig()
	fmt.Printf("Config: Port=%d, Verbose=%v\n", cfg.Port, cfg.Verbose)

	// Test Map
	let doubled = processPort(getPort())
	if doubled.IsSome() {
		fmt.Printf("Doubled port: %d\n", doubled.MustSome())
	}

	// Test Filter
	let validated = validatePort(Some(8080))
	if validated.IsSome() {
		fmt.Printf("Valid port: %d\n", validated.MustSome())
	}

	let invalidPort = validatePort(Some(100))
	if invalidPort.IsNone() {
		fmt.Println("Invalid port filtered out")
	}

	// Test AndThen
	let adjustedPort = getValidPort(10)
	if adjustedPort.IsSome() {
		fmt.Printf("Adjusted port: %d\n", adjustedPort.MustSome())
	}

	// Test complex chaining
	let final = processConfig(true)
	if final.IsSome() {
		fmt.Printf("Final port: %d\n", final.MustSome())
	} else {
		fmt.Println("No final port")
	}
}
