package main

import "fmt"

// Test: Error propagation with TypeScript-style lambda transform
// Feature: error-propagation
// Complexity: intermediate

// This test demonstrates the ? (err) => transform and ? err => transform
// syntax for custom error transformation using TypeScript-style lambdas.

func loadConfig(path string) (Config, error) {
	tmp, err := readFile(path)
	if err != nil {
		return Config{}, func(e __TYPE_INFERENCE_NEEDED) { return fmt.Errorf("read failed: %w", e) }(err)
	}
	content := tmp

	tmp1, err1 := parseJSON(content)
	if err1 != nil {
		return Config{}, func(err __TYPE_INFERENCE_NEEDED) { return fmt.Errorf("parse failed: %w", err) }(err1)
	}
	config := tmp1
	return config, nil
}

func processData(data []byte) (Result, error) {
	tmp, err := parse(data)
	if err != nil {
		return Result{}, func(err __TYPE_INFERENCE_NEEDED) { return wrapError("parse", err) }(err)
	}
	parsed := tmp

	tmp1, err1 := validate(parsed)
	if err1 != nil {
		return Result{}, func(e __TYPE_INFERENCE_NEEDED) { return wrapError("validate", e) }(err1)
	}
	validated := tmp1
	return validated, nil
}

func wrapError(op string, err error) error {
	return fmt.Errorf("%s operation failed: %w", op, err)
}

type Config struct {
	Name string
}

type Result struct {
	Value int
}

func readFile(path string) ([]byte, error) {
	return []byte("{}"), nil
}

func parseJSON(data []byte) (Config, error) {
	return Config{Name: "test"}, nil
}

func parse(data []byte) (Result, error) {
	return Result{Value: 42}, nil
}

func validate(r Result) (Result, error) {
	return r, nil
}
