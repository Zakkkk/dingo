package main

import (
	"database/sql"
	"github.com/MadAppGang/dingo/pkg/dgo"
)

// Custom error type with struct literal syntax
type ServiceError struct {
	Code    string
	Message string
}

func (e ServiceError) Error() string {
	return e.Code + ": " + e.Message
}

// Test basic struct literal with err.Error()
func FindOrders(db *sql.DB) dgo.Result[[]string, ServiceError] {
	tmp, err := db.Query("SELECT * FROM orders")

	if err != nil {
		return ResultSliceStringServiceErrorErr(ServiceError{Code: "DB_ERROR", Message: err.Error()})
	}
	var rows = tmp
	defer rows.Close()
	return ResultSliceStringServiceErrorOk([]string{"order1", "order2"})
}
func main() {
	var db *sql.DB = nil
	result := FindOrders(db)
	if result.IsErr() {
		println("Error:", result.err.Error())
	}
}
