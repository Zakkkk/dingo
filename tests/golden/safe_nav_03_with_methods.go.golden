package main

// Test: Safe navigation with method calls
// Feature: ?. with methods and function calls
// Complexity: advanced

type Config struct {
	timeout *int
}

func (c *Config) getTimeout() *int {
	return c.timeout
}
func (c *Config) validate() bool {
	return c.timeout != nil && *c.timeout > 0
}
func main() {
	config := &Config{timeout: nil}

	// Safe navigation with method calls
	tmp, err := config

	if err != nil {
		return nil, err
	}
	var timeout = tmp
	tmp1, err1 := config

	if err1 != nil {
		return nil, err1
	}
	var isValid = tmp1

	// Chained with null coalescing
	tmp2, err2 := config

	if err2 != nil {
		return nil, err2
	}
	var actualTimeout = tmp2

	println("Timeout:", timeout, "Valid:", isValid, "Actual:", actualTimeout)
}
