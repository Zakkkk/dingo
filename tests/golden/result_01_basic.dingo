// Test: Basic Result[T, E] usage with generic types
// Feature: Result type via dgo package
// Complexity: basic
package main

import "errors"

func divide(a float64, b float64) Result[float64, error] {
	if b == 0.0 {
		return Err[float64, error](errors.New("division by zero"))
	}
	return Ok[float64, error](a / b)
}

func main() {
	let result = divide(10.0, 2.0)
	if result.IsOk() {
		let v = result.MustOk()
		println("Result:", v)
	}
}
