package main

import "fmt"

// Test: Error propagation with TypeScript-style lambda transform
// Feature: error-propagation
// Complexity: intermediate

// This test demonstrates the ? (err) => transform and ? err => transform
// syntax for custom error transformation using TypeScript-style lambdas.

func loadConfig(path string) (Config, error) {
	let content = readFile(path) ? (e) => fmt.Errorf("read failed: %w", e)
	let config = parseJSON(content) ? err => fmt.Errorf("parse failed: %w", err)
	return config, nil
}

func processData(data []byte) (Result, error) {
	let parsed = parse(data) ? (err) => wrapError("parse", err)
	let validated = validate(parsed) ? e => wrapError("validate", e)
	return validated, nil
}

func wrapError(op string, err error) error {
	return fmt.Errorf("%s operation failed: %w", op, err)
}

type Config struct {
	Name string
}

type Result struct {
	Value int
}

func readFile(path string) ([]byte, error) {
	return []byte("{}"), nil
}

func parseJSON(data []byte) (Config, error) {
	return Config{Name: "test"}, nil
}

func parse(data []byte) (Result, error) {
	return Result{Value: 42}, nil
}

func validate(r Result) (Result, error) {
	return r, nil
}
