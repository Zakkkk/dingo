package main

import (
	"database/sql"
	"github.com/MadAppGang/dingo/pkg/dgo"
)

// Custom error type for multiline testing
type ServiceError struct {
	Code    string
	Message string
	Context string
}

func (e ServiceError) Error() string {
	return e.Code + ": " + e.Message + " (" + e.Context + ")"
}

// Test multiple error propagations in sequence (not multiline literal)
func QueryOrders(db *sql.DB) dgo.Result[[]string, ServiceError] {
	tmp, err := db.Query("SELECT * FROM orders")

	if err != nil {
		return ResultSliceStringServiceErrorErr(ServiceError{Code: "DB_ERROR", Message: err.Error(), Context: "QueryOrders"})
	}
	var rows = tmp
	defer rows.Close()

	// Second error propagation
	tmp1, err1 := db.Query("SELECT * FROM data")

	if err1 != nil {
		return ResultSliceStringServiceErrorErr(ServiceError{Code: "QUERY_ERROR", Message: err.Error(), Context: "data query"})
	}
	var data = tmp1
	defer data.Close()

	return ResultSliceStringServiceErrorOk([]string{"order1"})
}
func main() {
	var db *sql.DB = nil
	result := QueryOrders(db)
	if result.IsErr() {
		println("Error:", result.err.Error())
	}
}
