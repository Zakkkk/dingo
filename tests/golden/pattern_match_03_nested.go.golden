package main

import "errors"

// Test: Nested pattern matching
// Feature: Match with nested enum patterns
// Complexity: advanced


type ResultTag uint8

const (
	ResultTagOk ResultTag = iota
	ResultTagErr
)

type Result struct {
	tag ResultTag
	err *error
	ok  *Value
}

func ResultOk(arg0 Value) Result {
	return Result{tag: ResultTagOk, ok: &arg0}
}
func ResultErr(arg0 error) Result {
	return Result{tag: ResultTagErr, err: &arg0}
}
func (e Result) IsOk() bool {
	return e.tag == ResultTagOk
}
func (e Result) IsErr() bool {
	return e.tag == ResultTagErr
}
func (r Result) Map(fn func(Value) Value) Result {
	switch r.tag {
	case ResultTagOk:
		if r.ok != nil {
			return ResultOk(fn(*r.ok))
		}
	case ResultTagErr:
		return r
	}
	panic("invalid Result state")
}
func (r Result) AndThen(fn func(Value) Result) Result {
	switch r.tag {
	case ResultTagOk:
		if r.ok != nil {
			return fn(*r.ok)
		}
	case ResultTagErr:
		return r
	}
	panic("invalid Result state")
}


type ValueTag uint8

const (
	ValueTagInt ValueTag = iota
	ValueTagString
)

type Value struct {
	tag    ValueTag
	int    *int
	string *string
}
func ValueInt(arg0 int) Value {
	return Value{tag: ValueTagInt, int: &arg0}
}
func ValueString(arg0 string) Value {
	return Value{tag: ValueTagString, string: &arg0}
}
func (e Value) IsInt() bool {
	return e.tag == ValueTagInt
}
func (e Value) IsString() bool {
	return e.tag == ValueTagString
}
func processResult(r Result) string {
	var matchResult __TYPE_INFERENCE_NEEDED
	// DINGO_MATCH_START: r
	scrutinee := r
	switch scrutinee.tag {
	case ResultOkTag:
		// DINGO_PATTERN: ResultOk(ValueInt(n))
		ValueInt(n) := scrutinee.ValueInt(n)
		matchResult = "Got integer: " + string(n)
	case ResultOkTag:
		// DINGO_PATTERN: ResultOk(ValueString(s))
		ValueString(s) := scrutinee.ValueString(s)
		matchResult = "Got string: " + s
	case ResultErrTag:
		// DINGO_PATTERN: ResultErr(e)
		e := scrutinee.E
		matchResult = "Error: " + e.Error()
	}
	return matchResult
	// DINGO_MATCH_END

}
func main() {
	result1 := ResultOk(ValueInt(42))
	result2 := ResultOk(ValueString("hello"))
	result3 := ResultErr(errors.New("failed"))

	println(processResult(result1))
	println(processResult(result2))
	println(processResult(result3))
}
