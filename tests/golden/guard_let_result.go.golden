package main

import (
	"errors"
	"fmt"
)


type ResultTag uint8

const (
	ResultTagOk ResultTag = iota
	ResultTagErr
)

type Result struct {
	tag ResultTag
	err *error
	ok  *string
}

func ResultOk(arg0 string) Result {
	return Result{tag: ResultTagOk, ok: &arg0}
}
func ResultErr(arg0 error) Result {
	return Result{tag: ResultTagErr, err: &arg0}
}
func (e Result) IsOk() bool {
	return e.tag == ResultTagOk
}
func (e Result) IsErr() bool {
	return e.tag == ResultTagErr
}
func (r Result) Map(fn func(string) string) Result {
	switch r.tag {
	case ResultTagOk:
		if r.ok != nil {
			return ResultOk(fn(*r.ok))
		}
	case ResultTagErr:
		return r
	}
	panic("invalid Result state")
}
func (r Result) AndThen(fn func(string) Result) Result {
	switch r.tag {
	case ResultTagOk:
		if r.ok != nil {
			return fn(*r.ok)
		}
	case ResultTagErr:
		return r
	}
	panic("invalid Result state")
}
func FindUser(id int) Result {
	if id > 0 {
		return ResultOk(fmt.Sprintf("User%d", id))
	}
	return ResultErr(errors.New("user not found"))
}
func FindOrder(userID int) Result {
	if userID == 1 {
		return ResultOk("Order123")
	}
	return ResultErr(errors.New("order not found"))
}

// Basic guard let with Result
func GetUserOrder(userID int) Result {
	userResult := FindUser(userID)

	if userResult.IsErr() {
		err := *userResult.err
		return ResultErr(err)
	}
	user := *userResult.ok

	orderResult := FindOrder(userID)

	if orderResult.IsErr() {
		err := *orderResult.err
		return ResultErr(err)
	}
	order := *orderResult.ok

	return ResultOk(fmt.Sprintf("%s has %s", user, order))
}

// Multiple guard lets in sequence
func ProcessUserOrders(userID int) Result {
	tmp := FindUser(userID)

	if tmp.IsErr() {
		err := *tmp.err
		return ResultErr(err)
	}
	user := *tmp.ok

	tmp1 := FindOrder(userID)

	if tmp1.IsErr() {
		err := *tmp1.err
		return ResultErr(err)
	}
	order := *tmp1.ok

	fmt.Printf("Processing: %s, %s\n", user, order)
	return ResultOk("success")
}

// Custom error handling in else block
func GetUserWithLogging(userID int) Result {
	tmp2 := FindUser(userID)

	if tmp2.IsErr() {
		err := *tmp2.err
		fmt.Printf("Failed to find user %d: %v\n", userID, err)
		return ResultErr(fmt.Errorf("user lookup failed: %w", err))
	}
	user := *tmp2.ok

	fmt.Printf("Found user: %s\n", user)
	return ResultOk(user)
}
func main() {
	result := GetUserOrder(1)
	if result.IsOk() {
		fmt.Println(*result.ok)
	}

	result2 := ProcessUserOrders(1)
	if result2.IsOk() {
		fmt.Println(*result2.ok)
	}

	result3 := GetUserWithLogging(0)
	if result3.IsErr() {
		fmt.Println("Error:", *result3.err)
	}
}
