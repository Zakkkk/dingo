package main

import "fmt"

func main() {
	nums := []int{1, 2, 3, 4, 5}

	// find() returns Option[T]
	result := func() OptionInt {
		for _, x := range nums {
			if x > 3 {
				return OptionIntSome(x)
			}
		}
		return OptionIntNone()
	}()

	if result.IsSome() {
		fmt.Printf("Found: %d\n", result.Unwrap())
	} else {
		fmt.Println("Not found")
	}
}
