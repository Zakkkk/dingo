// Test: Result[T, E] with method chaining
// Feature: Result type with Map and AndThen
// Complexity: advanced
package main

import "errors"

func parse(s string) Result[int, error] {
	if s == "" {
		return Err[int, error](errors.New("empty string"))
	}
	return Ok[int, error](len(s))
}

func validate(n int) Result[int, error] {
	if n < 5 {
		return Err[int, error](errors.New("too short"))
	}
	return Ok[int, error](n)
}

func processInput(input string) Result[int, error] {
	return parse(input).
		AndThen(|x| validate(x)).
		Map(|x| x * 2)
}

func main() {
	let result = processInput("hello world")
	if result.IsOk() {
		println("Result:", result.MustOk())
	}
}
