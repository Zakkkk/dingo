type User struct {
	name    string
	address AddressOption
}

type Address struct {
	city StringOption
	zip  string
}
func main() {
	// Test 1: Separate safe navigation and null coalescing
	// Note: Direct combination of ?. and ?? is not supported due to multi-line IIFE complexity
	var user UserOption = getUser(1)
	tmp, err := user

	if err != nil {
		return nil, err
	}
	var userNameOpt = tmp
	tmp1, err1 := userNameOpt

	if err1 != nil {
		return nil, err1
	}
	var userName = tmp1

	// Test 2: user?.address?.city ?? defaultCity
	defaultCity := "San Francisco"
	tmp2, err2 := user

	if err2 != nil {
		return nil, err2
	}
	var addressOpt = tmp2
	tmp3, err3 := addressOpt

	if err3 != nil {
		return nil, err3
	}
	var cityOpt = tmp3
	tmp4, err4 := cityOpt

	if err4 != nil {
		return nil, err4
	}
	var city = tmp4

	// Test 3: Chain with method calls
	var profile UserOption = fetchProfile()
	tmp5, err5 := profile

	if err5 != nil {
		return nil, err5
	}
	var emailOpt = tmp5
	tmp6, err6 := emailOpt

	if err6 != nil {
		return nil, err6
	}
	var email = tmp6

	// Test 4: Multiple safe nav with different fallbacks
	var user2 UserOption = getUser(2)
	tmp7, err7 := user2

	if err7 != nil {
		return nil, err7
	}
	var addressOpt2 = tmp7
	tmp8, err8 := addressOpt2

	if err8 != nil {
		return nil, err8
	}
	var zipOpt = tmp8
	tmp9, err9 := addressOpt2

	if err9 != nil {
		return nil, err9
	}
	var cityOpt2 = tmp9
	tmp10, err10 := zipOpt

	if err10 != nil {
		return nil, err10
	}
	var zip = tmp10
	tmp11, err11 := cityOpt2

	if err11 != nil {
		return nil, err11
	}
	var city2 = tmp11

	println("User:", userName, "City:", city, "Email:", email)
	println("Zip:", zip, "City2:", city2)
}
func getUser(id int) UserOption {
	if id == 1 {
		addr := AddressOptionSome(Address{
			city: StringOptionSome("New York"),
			zip:  "10001",
		})
		return UserOptionSome(User{name: "Alice", address: addr})
	}
	return UserOptionNone()
}
func fetchProfile() UserOption {
	return UserOptionNone()
}
func (u User) getEmail() StringOption {
	return StringOptionSome(u.name + "@example.com")
}
