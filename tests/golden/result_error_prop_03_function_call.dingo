package main

import "database/sql"

// Custom error type with function call pattern
type ServiceError struct {
	Code    string
	Message string
}

func (e ServiceError) Error() string {
	return e.Code + ": " + e.Message
}

// Wrapper function
func WrapDBError(err: error) ServiceError {
	return ServiceError{Code: "DB_ERROR", Message: err.Error()}
}

// Test WrapFunc(err) pattern
func FindProducts(db: *sql.DB) Result<[]string, ServiceError> {
	let rows = db.Query("SELECT * FROM products")? WrapDBError(err)
	defer rows.Close()
	return ResultSliceStringServiceErrorOk([]string{"product1", "product2"})
}

func main() {
	let db: *sql.DB = nil
	let result = FindProducts(db)
	if result.IsErr() {
		println("Error:", result.err.Error())
	}
}
