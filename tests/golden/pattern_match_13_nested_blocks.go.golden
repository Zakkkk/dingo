package main

import "errors"

// Test: Nested match blocks
// Feature: Match expression containing nested match expressions in arms
// Complexity: advanced


type MyResultTag uint8

const (
	MyResultTagMyOk MyResultTag = iota
	MyResultTagMyErr
)

type MyResult struct {
	tag   MyResultTag
	myerr *error
	myok  *MyOption
}

func MyResultMyOk(arg0 MyOption) MyResult {
	return MyResult{tag: MyResultTagMyOk, myok: &arg0}
}
func MyResultMyErr(arg0 error) MyResult {
	return MyResult{tag: MyResultTagMyErr, myerr: &arg0}
}
func (e MyResult) IsMyOk() bool {
	return e.tag == MyResultTagMyOk
}
func (e MyResult) IsMyErr() bool {
	return e.tag == MyResultTagMyErr
}


type MyOptionTag uint8

const (
	MyOptionTagMySome MyOptionTag = iota
	MyOptionTagMyNone
)

type MyOption struct {
	tag    MyOptionTag
	mysome *int
}
func MyOptionMySome(arg0 int) MyOption {
	return MyOption{tag: MyOptionTagMySome, mysome: &arg0}
}
func MyOptionMyNone() MyOption {
	return MyOption{tag: MyOptionTagMyNone}
}
func (e MyOption) IsMySome() bool {
	return e.tag == MyOptionTagMySome
}
func (e MyOption) IsMyNone() bool {
	return e.tag == MyOptionTagMyNone
}
func processNestedMatch(result MyResult) int {
	var __match_result_0 interface{}
	// DINGO_MATCH_START: result
	scrutinee := result
	switch scrutinee.tag {
	case MyResultTagMyOk:
		inner := *scrutinee.myok
		// DINGO_PATTERN: MyOk(inner)
		// DINGO_MATCH_START: inner
		scrutinee2 := inner
		switch scrutinee2.tag {
		case MyOptionTagMySome:
			val := *scrutinee2.mysome
			// DINGO_PATTERN: MySome(val)
			val
		case MyOptionTagMyNone:
			// DINGO_PATTERN: MyNone
			0
		}
		panic("unreachable: match is exhaustive")
	// DINGO_MATCH_END

	case MyResultTagMyErr:
		e := *scrutinee.myerr
		// DINGO_PATTERN: MyErr(e)
		__match_result_0 = -1
	}
	return __match_result_0
	// DINGO_MATCH_END

}
func main() {
	r1 := MyResultMyOk(MyOptionMySome(42))
	r2 := MyResultMyOk(MyOptionMyNone())
	r3 := MyResultMyErr(errors.New("failed"))

	println(processNestedMatch(r1)) // 42
	println(processNestedMatch(r2)) // 0
	println(processNestedMatch(r3)) // -1
}
