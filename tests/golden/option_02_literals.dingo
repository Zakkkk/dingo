// Test: Option[T] with literal values (non-addressable)
// Feature: Option type via dgo package with literal wrapping
// Complexity: basic
package main

import "fmt"

func main() {
	// Some() with literal values
	// The transpiler wraps these correctly via dgo.Some()
	let intOpt = Some(42)
	let strOpt = Some("hello")
	let floatOpt = Some(3.14)
	let boolOpt = Some(true)

	// Some() with variables (addressable - standard path)
	let x = 100
	let varOpt = Some(x)

	// Print results using dgo.Option[T] methods
	if intOpt.IsSome() {
		fmt.Printf("intOpt: %d\n", intOpt.MustSome())
	}

	if strOpt.IsSome() {
		fmt.Printf("strOpt: %s\n", strOpt.MustSome())
	}

	if floatOpt.IsSome() {
		fmt.Printf("floatOpt: %.2f\n", floatOpt.MustSome())
	}

	if boolOpt.IsSome() {
		fmt.Printf("boolOpt: %t\n", boolOpt.MustSome())
	}

	if varOpt.IsSome() {
		fmt.Printf("varOpt: %d\n", varOpt.MustSome())
	}
}
