package main

// Test: Guards with 'where' keyword (Swift-style)
// Feature: Swift-style 'where' guards with complex boolean expressions
// Complexity: intermediate
// Limitation: where guards with NESTED patterns not yet supported

type Option interface {
	isOption()
	IsSome() bool
	IsNone() bool
}

type OptionSome struct{ Value int }

func (OptionSome) isOption()         {}
func NewOptionSome(value int) Option { return OptionSome{Value: value} }

type OptionNone struct{}

func (OptionNone) isOption() {}
func NewOptionNone() Option  { return OptionNone{} }

func IsOptionSome(v Option) bool { _, ok := v.(OptionSome); return ok }
func IsOptionNone(v Option) bool { _, ok := v.(OptionNone); return ok }
func (OptionSome) IsSome() bool  { return true }
func (OptionSome) IsNone() bool  { return false }
func (OptionNone) IsSome() bool  { return false }
func (OptionNone) IsNone() bool  { return true }

type Result interface {
	isResult()
	IsOk() bool
	IsErr() bool
}

type ResultOk struct{ Value int }

func (ResultOk) isResult()         {}
func NewResultOk(value int) Result { return ResultOk{Value: value} }

type ResultErr struct{ Value error }

func (ResultErr) isResult()           {}
func NewResultErr(value error) Result { return ResultErr{Value: value} }

func IsResultOk(v Result) bool  { _, ok := v.(ResultOk); return ok }
func IsResultErr(v Result) bool { _, ok := v.(ResultErr); return ok }
func (ResultOk) IsOk() bool     { return true }
func (ResultOk) IsErr() bool    { return false }
func (ResultErr) IsOk() bool    { return false }
func (ResultErr) IsErr() bool   { return true }

// Using 'where' keyword (Swift-style)
func analyzeValue(opt Option) string {
	return func() string {
		switch v := opt.(type) {
		case OptionSome:
			x := v.x
			if x > 100 {
				return "large"
			}
			panic("match guard failed without fallback")
		case OptionSome:
			x := v.x
			if x > 10 {
				return "medium"
			}
			panic("match guard failed without fallback")
		case OptionSome:
			x := v.x
			if x > 0 {
				return "small"
			}
			panic("match guard failed without fallback")
		case OptionSome:
			return "non-positive"
		default:
			OptionNone := opt
			return "none"
		}
	}()
}

// Simple pattern with where guards (NOT nested)
func processResult(result Result) string {
	return func() string {
		switch v := result.(type) {
		case ResultOk:
			val := v.val
			if val > 100 {
				return "large value"
			}
			panic("match guard failed without fallback")
		case ResultOk:
			val := v.val
			if val > 0 {
				return "positive value"
			}
			panic("match guard failed without fallback")
		case ResultOk:
			return "non-positive value"
		case ResultErr:
			return "error"
		}
	}()
}

// Guard fallthrough demonstration
func categorize(opt Option) string {
	return func() string {
		switch v := opt.(type) {
		case OptionSome:
			x := v.x
			if x%3 == 0 && x%5 == 0 {
				return "fizzbuzz"
			}
			panic("match guard failed without fallback")
		case OptionSome:
			x := v.x
			if x%3 == 0 {
				return "fizz"
			}
			panic("match guard failed without fallback")
		case OptionSome:
			x := v.x
			if x%5 == 0 {
				return "buzz"
			}
			panic("match guard failed without fallback")
		case OptionSome:
			x := v.x
			return "number"
		default:
			OptionNone := opt
			return "empty"
		}
	}()
}

func main() {
	println(analyzeValue(OptionSome(150)))
	println(processResult(ResultOk(42)))
	println(categorize(OptionSome(15)))
}
