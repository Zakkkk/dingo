package main

// Test: Complex ternary expressions
// Feature: Ternary with function calls and expressions
// Complexity: advanced

func getDiscount(isPremium bool, amount int) int {
	return func() int {
		if isPremium {
			return amount * 20 / 100
		}
		return amount * 10 / 100
	}()
}
func main() {
	amount := 100
	isPremium := true

	// Ternary with function calls
	discount := func() any {
		if isPremium {
			return getDiscount(true, amount)
		}
		return getDiscount(false, amount)
	}()

	// Ternary with complex expressions
	price := amount - (func() int {
		if isPremium {
			return amount / 5
		}
		return amount / 10
	}())

	// Ternary in function argument
	println("Discount:", discount, "Price:", price)
}
