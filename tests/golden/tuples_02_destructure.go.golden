package main

// Test: Tuple destructuring patterns
// Feature: Advanced tuple destructuring
// Complexity: intermediate

func getUserInfo() (string, int, bool) {
	return "Alice", 30, true
}
func swap(a int, b int) (int, int) {
	return b, a
}
func main() {
	// Basic destructuring
	tmp := getUserInfo()
	name, age, active := tmp._0, tmp._1, tmp._2

	// Ignore some values with _
	tmp1 := getUserInfo()
	username, _, _ := tmp1._0, tmp1._1, tmp1._2

	// Swap using tuples
	x := 10
	y := 20
	tmp2 := swap(x, y)
	x, y := tmp2._0, tmp2._1

	println("User:", name, age, active)
	println("Username:", username)
	println("Swapped:", x, y)
}
