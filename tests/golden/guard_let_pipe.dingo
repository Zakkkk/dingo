// Test: Guard Let with pipe binding variations
// Feature: Guard let with custom error binding names
// Complexity: intermediate
package main

import (
	"errors"
	"fmt"
)

enum Result {
	Ok(string),
	Err(error),
}

enum Option {
	Some(int),
	None,
}

func FindUser(id int) Result {
	if id > 0 {
		return NewResultOk(fmt.Sprintf("User%d", id))
	}
	return NewResultErr(errors.New("user not found"))
}

func GetCount(id int) Option {
	if id > 0 {
		return NewOptionSome(id * 10)
	}
	return NewOptionNone()
}

// Test explicit |err| binding
func TestExplicitErrBinding(id int) Result {
	guard let user = FindUser(id) else |err| {
		return NewResultErr(err)
	}
	return NewResultOk(user)
}

// Test custom |e| binding
func TestCustomBinding(id int) Result {
	guard let user = FindUser(id) else |e| {
		fmt.Printf("Custom error: %v\n", e)
		return NewResultErr(fmt.Errorf("wrapped: %w", e))
	}
	return NewResultOk(user)
}

// Test no binding with Result (but not using err)
func TestNoBindingResult(id int) string {
	guard let user = FindUser(id) else {
		return "failed"
	}
	return user
}

// Test no binding with Option
func TestNoBindingOption(id int) string {
	guard let count = GetCount(id) else {
		return "no count"
	}
	return fmt.Sprintf("Count: %d", count)
}

// Test complex else body with custom binding name
func TestComplexElseBody(id int) Result {
	guard let user = FindUser(id) else |failure| {
		fmt.Printf("Operation failed with: %v\n", failure)
		if id < 0 {
			return NewResultErr(fmt.Errorf("negative id: %w", failure))
		}
		return NewResultErr(fmt.Errorf("zero id: %w", failure))
	}

	guard let count = GetCount(id) else {
		return NewResultErr(errors.New("count not available"))
	}

	return NewResultOk(fmt.Sprintf("%s has count %d", user, count))
}

// Test multiple bindings with different names
func TestMultipleBindings(id1 int, id2 int) string {
	guard let user1 = FindUser(id1) else |err1| {
		fmt.Printf("First error: %v\n", err1)
		return "first failed"
	}

	guard let user2 = FindUser(id2) else |err2| {
		fmt.Printf("Second error: %v\n", err2)
		return "second failed"
	}

	return fmt.Sprintf("Got: %s and %s", user1, user2)
}

func main() {
	let result1 = TestExplicitErrBinding(1)
	switch v := result1.(type) {
	case ResultOk:
		fmt.Println(v.Value)
	}

	let result2 = TestCustomBinding(0)
	switch v := result2.(type) {
	case ResultErr:
		fmt.Println("Error:", v.Value)
	}

	let result3 = TestNoBindingResult(1)
	fmt.Println(result3)

	let result4 = TestNoBindingOption(5)
	fmt.Println(result4)

	let result5 = TestComplexElseBody(1)
	switch v := result5.(type) {
	case ResultOk:
		fmt.Println(v.Value)
	}

	let result6 = TestMultipleBindings(1, 2)
	fmt.Println(result6)
}
