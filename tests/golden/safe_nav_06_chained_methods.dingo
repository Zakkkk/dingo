// Test: Chained method calls with safe navigation operator
// Feature: Safe Navigation (?.) - Chained Methods
// Complexity: intermediate
package main

type User struct {
	name string
}

type Profile struct {
	bio string
}

func (u User) getName() Option[string] {
	if u.name != "" {
		return Some(u.name)
	}
	return None[string]()
}

func (s Option[string]) toUpper() Option[string] {
	if s.IsNone() {
		return None[string]()
	}
	let str = s.MustSome()
	// Simplified uppercase conversion
	return Some(str)
}

func (u User) getProfile() Option[Profile] {
	return Some(Profile{bio: "Engineer"})
}

func (p Profile) getBio() Option[string] {
	if p.bio != "" {
		return Some(p.bio)
	}
	return None[string]()
}

func getUser(id int) Option[User] {
	if id > 0 {
		return Some(User{name: "Alice"})
	}
	return None[User]()
}

func main() {
	let user = getUser(1)

	// Chained methods on same type: user?.getName()?.toUpper()
	let upperName = user?.getName()?.toUpper()
	println(upperName)

	// Chained methods across types: user?.getProfile()?.getBio()
	let bio = user?.getProfile()?.getBio()
	println(bio)
}
