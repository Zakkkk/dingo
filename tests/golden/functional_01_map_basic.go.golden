package main

import "fmt"

func main() {
	nums := []int{1, 2, 3, 4, 5}

	// Basic map operation with Go func literal
	doubled := func() []int {
		tmp := make([]int, 0, len(nums))
		for _, x := range nums {
			tmp = append(tmp, x*2)
		}
		return tmp
	}()

	for _, n := range doubled {
		fmt.Println(n)
	}
}
