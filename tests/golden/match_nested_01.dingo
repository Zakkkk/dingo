// P0 Feature: Nested patterns
// Match expressions should support nested patterns like Ok(Some(x))
package main

import "fmt"

// WrappedValue demonstrates nested Result and Option types
type WrappedValue = Result[Option[int], error]

func unwrapValue(wrapped WrappedValue) int {
	return match wrapped {
		Ok(Some(value)) => value,              // Nested: Ok containing Some
		Ok(None) => 0,                         // Ok containing None
		Err(e) => -1,                          // Error case
	}
}

func processNested(wrapped WrappedValue) string {
	return match wrapped {
		Ok(Some(x)) if x > 100 => fmt.Sprintf("High value: %d", x),
		Ok(Some(x)) => fmt.Sprintf("Value: %d", x),
		Ok(None) => "No value",
		Err(e) => fmt.Sprintf("Error: %v", e),
	}
}

func main() {
	// Test nested patterns
	val1 := Ok[Option[int], error](Some(42))
	val2 := Ok[Option[int], error](None[int]())
	val3 := Err[Option[int], error](fmt.Errorf("failed"))

	fmt.Println(unwrapValue(val1))  // 42
	fmt.Println(unwrapValue(val2))  // 0
	fmt.Println(unwrapValue(val3))  // -1

	fmt.Println(processNested(val1)) // Value: 42
	fmt.Println(processNested(val2)) // No value
	fmt.Println(processNested(val3)) // Error: failed
}
