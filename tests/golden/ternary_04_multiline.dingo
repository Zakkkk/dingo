package main

// Test: Multi-line ternary expressions
// Feature: Ternary operator with newlines after ? and :
// Complexity: intermediate

func getRegion(region string, aws string, def string) string {
	// Case 1: Newline after ?
	let result1 = region != "" ?
		region : ""

	// Case 2: Newline after :
	let result2 = aws != "" ? aws :
		def

	// Case 3: Newlines after both ? and :
	let result3 = region != "" ?
		region :
		"default"

	// Case 4: Chained ternary with newlines (right-to-left associativity)
	let regionFallback = region != "" ? region :
		aws != "" ? aws :
		def != "" ? def :
		"us-east-1"

	// Case 5: Complex nested expression with newlines
	let config = getConfig()
	let host = (config?.Host ?? "") != "" ?
		config?.Host ?? "" :
		"localhost"

	// Case 6: Multi-line with arithmetic expressions
	let score = 85
	let grade = score >= 90 ?
		"A" :
		score >= 80 ? "B" :
		score >= 70 ? "C" :
		"F"

	// Case 7: Multi-line with function calls
	let isPremium = true
	let amount = 100
	let discount = isPremium ?
		getDiscount(true, amount) :
		getDiscount(false, amount)

	return regionFallback
}

func getDiscount(isPremium bool, amount int) int {
	return isPremium ? amount * 20 / 100 : amount * 10 / 100
}

func getConfig() *Config {
	return &Config{Host: "example.com"}
}

type Config struct {
	Host string
}

func main() {
	let result = getRegion("", "", "default")
	println("Region:", result)
}
