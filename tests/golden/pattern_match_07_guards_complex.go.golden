package main

import "strings"

// Test: Complex guard expressions with mixed 'if' and 'where'
// Feature: Guards with complex boolean logic, field access, and method calls
// Complexity: advanced

type Request interface {
	isRequest()
	IsGet() bool
	IsPost() bool
	IsDelete() bool
}

type RequestGet struct{ Value string }

func (RequestGet) isRequest()            {}
func NewRequestGet(value string) Request { return RequestGet{Value: value} }

type RequestPost struct {
	Value0 string
	Value1 string
}

func (RequestPost) isRequest() {}
func NewRequestPost(value0 string, value1 string) Request {
	return RequestPost{Value0: value0, Value1: value1}
}

type RequestDelete struct{ Value string }

func (RequestDelete) isRequest()            {}
func NewRequestDelete(value string) Request { return RequestDelete{Value: value} }

func IsRequestGet(v Request) bool    { _, ok := v.(RequestGet); return ok }
func IsRequestPost(v Request) bool   { _, ok := v.(RequestPost); return ok }
func IsRequestDelete(v Request) bool { _, ok := v.(RequestDelete); return ok }
func (RequestGet) IsGet() bool       { return true }
func (RequestGet) IsPost() bool      { return false }
func (RequestGet) IsDelete() bool    { return false }
func (RequestPost) IsGet() bool      { return false }
func (RequestPost) IsPost() bool     { return true }
func (RequestPost) IsDelete() bool   { return false }
func (RequestDelete) IsGet() bool    { return false }
func (RequestDelete) IsPost() bool   { return false }
func (RequestDelete) IsDelete() bool { return true }

type Status interface {
	isStatus()
	IsActive() bool
	IsPaused() bool
	IsStopped() bool
}

type StatusActive struct{ Value int }

func (StatusActive) isStatus()         {}
func NewStatusActive(value int) Status { return StatusActive{Value: value} }

type StatusPaused struct{ Value int }

func (StatusPaused) isStatus()         {}
func NewStatusPaused(value int) Status { return StatusPaused{Value: value} }

type StatusStopped struct{}

func (StatusStopped) isStatus() {}
func NewStatusStopped() Status  { return StatusStopped{} }

func IsStatusActive(v Status) bool    { _, ok := v.(StatusActive); return ok }
func IsStatusPaused(v Status) bool    { _, ok := v.(StatusPaused); return ok }
func IsStatusStopped(v Status) bool   { _, ok := v.(StatusStopped); return ok }
func (StatusActive) IsActive() bool   { return true }
func (StatusActive) IsPaused() bool   { return false }
func (StatusActive) IsStopped() bool  { return false }
func (StatusPaused) IsActive() bool   { return false }
func (StatusPaused) IsPaused() bool   { return true }
func (StatusPaused) IsStopped() bool  { return false }
func (StatusStopped) IsActive() bool  { return false }
func (StatusStopped) IsPaused() bool  { return false }
func (StatusStopped) IsStopped() bool { return true }

// Mixed if/where keywords in same match
func routeRequest(req Request) string {
	return func() string {
		switch v := req.(type) {
		case Request_Get:
			path := v.path
			if strings.HasPrefix(path, "/api/") {
				return "API endpoint"
			}
			panic("match guard failed without fallback")
		case Request_Get:
			path := v.path
			if len(path) > 0 {
				return "static resource"
			}
			panic("match guard failed without fallback")
		case Request_Post:
			path := v.path
			body := v.body
			if len(body) > 100 && strings.Contains(path, "upload") {
				return "large upload"
			}
			panic("match guard failed without fallback")
		case Request_Post:
			body := v.body
			if len(body) > 0 {
				return "post request"
			}
			panic("match guard failed without fallback")
		case Request_Delete:
			path := v.path
			if isProtected(path) {
				return "forbidden"
			}
			panic("match guard failed without fallback")
		case Request_Delete:
			return "delete request"
		default:
			return "unknown"
		}
	}()
}

// Guards with logical operators
func classifyStatus(status Status) string {
	return func() string {
		switch v := status.(type) {
		case Status_Active:
			count := v.count
			if count > 1000 || count < 0 {
				return "unusual"
			}
			panic("match guard failed without fallback")
		case Status_Active:
			count := v.count
			if count >= 100 && count <= 1000 {
				return "normal"
			}
			panic("match guard failed without fallback")
		case Status_Active:
			return "low activity"
		case Status_Paused:
			duration := v.duration
			if duration > 3600 {
				return "long pause"
			}
			panic("match guard failed without fallback")
		case Status_Paused:
			if true {
				return "short pause"
			}
			panic("match guard failed without fallback")
		default:
			Status_Stopped := status
			return "stopped"
		}
	}()
}

