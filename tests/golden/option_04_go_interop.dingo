// Test: Option[T] interoperating with Go map lookups
// Feature: Option type + Go interop patterns
// Complexity: intermediate
package main

func findInMap(m map[string]string, key string) Option[string] {
	val, exists := m[key]
	if exists {
		return Some(val)
	}
	return None[string]()
}

func getOrDefault(opt Option[string], defaultVal string) string {
	return opt.SomeOr(defaultVal)
}

func main() {
	data := map[string]string{"name": "Alice"}
	let name = findInMap(data, "name")
	let age = findInMap(data, "age")

	println("Name:", getOrDefault(name, "Unknown"))
	println("Age:", getOrDefault(age, "N/A"))
}
