package main

import "fmt"


type OptionTag uint8

const (
	OptionTagSome OptionTag = iota
	OptionTagNone
)

type Option struct {
	tag  OptionTag
	some *string
}

func OptionSome(arg0 string) Option {
	return Option{tag: OptionTagSome, some: &arg0}
}
func OptionNone() Option {
	return Option{tag: OptionTagNone}
}
func (e Option) IsSome() bool {
	return e.tag == OptionTagSome
}
func (e Option) IsNone() bool {
	return e.tag == OptionTagNone
}
func (o Option) Map(fn func(string) string) Option {
	switch o.tag {
	case OptionTagSome:
		if o.some != nil {
			return OptionSome(fn(*o.some))
		}
	case OptionTagNone:
		return o
	}
	panic("invalid Option state")
}
func (o Option) AndThen(fn func(string) Option) Option {
	switch o.tag {
	case OptionTagSome:
		if o.some != nil {
			return fn(*o.some)
		}
	case OptionTagNone:
		return o
	}
	panic("invalid Option state")
}
func (o Option) Unwrap() string {
	if o.tag != OptionTagSome {
		panic("called Unwrap on None")
	}
	return *o.some
}
func FindUserByEmail(email string) Option {
	if email != "" {
		return OptionSome("User_" + email)
	}
	return OptionNone()
}
func GetPreference(userID int) Option {
	if userID > 0 {
		return OptionSome("dark_mode")
	}
	return OptionNone()
}

// Basic guard let with Option (no err binding)
func ProcessUser(maybeUser Option) string {

	if maybeUser.IsNone() {
		return "no user"
	}
	user := *maybeUser.some
	return fmt.Sprintf("Processing: %s", user)
}

// Multiple guard lets with Option
func GetUserSettings(email string, userID int) string {
	tmp := FindUserByEmail(email)

	if tmp.IsNone() {
		return "User not found"
	}
	user := *tmp.some

	tmp1 := GetPreference(userID)

	if tmp1.IsNone() {
		return "No preferences"
	}
	pref := *tmp1.some

	return fmt.Sprintf("%s prefers %s", user, pref)
}

// Different return types with Option
func ValidateUser(maybeUser Option) (string, bool) {

	if maybeUser.IsNone() {
		return "", false
	}
	user := *maybeUser.some
	return user, true
}
func main() {
	result1 := ProcessUser(OptionSome("Alice"))
	fmt.Println(result1)

	result2 := ProcessUser(OptionNone())
	fmt.Println(result2)

	result3 := GetUserSettings("alice@example.com", 1)
	fmt.Println(result3)

	user, ok := ValidateUser(OptionSome("Bob"))
	if ok {
		fmt.Printf("Valid user: %s\n", user)
	}
}
