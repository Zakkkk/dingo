type Tuple2AnyAny struct {
	_0 interface {
	}
	_1 interface {
	}
}
func findUser(id int) (OptionString, OptionInt) {
	if id > 0 {
		return OptionStringSome("User"), OptionInterfaceSome(id)
	}
	return Option_string_None(), Option_int_None()
}
func getIntResult() ResultIntString {
	return ResultIntError{tag: ResultTagOk, ok: func() *int {
		tmp2 := 42
		return &tmp2
	}()}
}
func getStringResult() ResultStringString {
	return ResultStringError{tag: ResultTagOk, ok: func() *string {
		tmp3 := "hello"
		return &tmp3
	}()}
}
func getOptions() (OptionInt, OptionString, OptionBool) {
	return OptionIntSome(10), Option_string_None(), OptionBoolSome(true)
}
func main() {

	tmp := findUser(1)
	nameOpt, idOpt := tmp._0, tmp._1
	if nameOpt.IsSome() && idOpt.IsSome() {
		println("User:", nameOpt.Unwrap(), idOpt.Unwrap())
	} else {
		println("Not found")
	}

	r1 := getIntResult()
	r2 := getStringResult()
	results := Tuple2AnyAny{_0: r1, _1: r2}
	tmp1 := results
	res1, res2 := tmp1._0, tmp1._1

	if res1.IsOk() && res2.IsOk() {
		println("Both ok:", res1.Unwrap(), res2.Unwrap())
	} else {
		println("At least one failed")
	}

	tmp2 := getOptions()
	numOpt, strOpt, boolOpt := tmp2._0, tmp2._1, tmp2._2
	println("Options:", numOpt.IsSome(), strOpt.IsSome(), boolOpt.IsSome())
}
