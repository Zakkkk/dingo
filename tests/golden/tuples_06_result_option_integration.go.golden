type Tuple2_Any_Any struct {
	_0 interface {
	}
	_1 interface {
	}
}

// Test: Tuples with Result and Option types
// Feature: Integration with Result[T,E] and Option[T]
// Complexity: intermediate

// Tuple of Options
func findUser(id int) (dgo.Option[string], dgo.Option[int]) {
	if id > 0 {
		return OptionStringSome("User"), OptionInterfaceSome(id)
	}
	return Option_string_None(), Option_int_None()
}

// Tuple of Results
func getIntResult() dgo.Result[int, string] {
	return dgo.Ok[int, string](42)
}
func getStringResult() dgo.Result[string, string] {
	return dgo.Ok[string, string]("hello")
}

// Tuple with mixed Option types
func getOptions() (dgo.Option[int], dgo.Option[string], dgo.Option[bool]) {
	return OptionIntSome(10), Option_string_None(), OptionBoolSome(true)
}
func main() {
	// Tuple of Options - destructure and check separately
	tmp := findUser(1)
	nameOpt, idOpt := tmp._0, tmp._1
	if nameOpt.IsSome() && idOpt.IsSome() {
		println("User:", nameOpt.Unwrap(), idOpt.Unwrap())
	} else {
		println("Not found")
	}

	// Create tuple of Results manually
	r1 := getIntResult()
	r2 := getStringResult()
	results := Tuple2_Any_Any{_0: r1, _1: r2}
	tmp1 := results
	res1, res2 := tmp1._0, tmp1._1

	if res1.IsOk() && res2.IsOk() {
		println("Both ok:", res1.Unwrap(), res2.Unwrap())
	} else {
		println("At least one failed")
	}

	// Tuple of mixed Options
	tmp2 := getOptions()
	numOpt, strOpt, boolOpt := tmp2._0, tmp2._1, tmp2._2
	println("Options:", numOpt.IsSome(), strOpt.IsSome(), boolOpt.IsSome())
}
