package main

type

// Test: Tuples with Result and Option types
// Feature: Integration with Result[T,E] and Option[T]
// Complexity: intermediate
ResultTag uint8

const (
	ResultTagOk ResultTag = iota
	ResultTagErr
)

type ResultIntString struct {
	tag ResultTag
	ok  *int
	err *string
}

func ResultIntStringOk(

// Tuple of Options
arg0 int) ResultIntString {
	return ResultIntString{tag: ResultTagOk, ok: &arg0}
}
func ResultIntStringErr(arg0 string) ResultIntString {
	return ResultIntString{tag: ResultTagErr, err: &

	// Tuple of Results
	arg0}
}
func (r ResultIntString) IsOk() bool {
	return r.tag == ResultTagOk
}
func (r ResultIntString) IsErr() bool {
	return r.tag == ResultTagErr
}
func (r ResultIntString) Unwrap(

// Tuple with mixed Option types
) int {
	if r.tag != ResultTagOk {
		panic("called Unwrap on Err")
	}
	if r.ok == nil {
		panic("Result contains nil Ok value")
	}
	return *r.ok
}
func (r ResultIntString) UnwrapOr(defaultValue int) int {

	// Tuple of Options - destructure and check separately
	if r.tag == ResultTagOk {
		return *r.ok
	}
	return defaultValue
}
func (r ResultIntString) UnwrapErr() string {
	if r.tag != ResultTagErr {
		panic("called UnwrapErr on Ok")
	}
	if r.err == nil {
		panic("Result contains nil Err value")
	}
	return *r.err
}
func (r ResultIntString) UnwrapOrElse(

// Create tuple of Results manually
fn func(string) int) int {
	if r.tag == ResultTagOk && r.ok != nil {
		return *r.ok
	}
	if r.err != nil {
		return fn(*r.err)
	}
	panic("Result in invalid state")
}
func (r ResultIntString) Map(fn func(int) interface{}) interface{} {
	if r.tag == ResultTagOk && r.ok != nil {
		u := fn(*r.ok)
		return struct {
			tag ResultTag
			ok  *interface{}
			err *string
		}{tag: ResultTagOk, ok: &

		// Tuple of mixed Options
		u}
	}
	return struct {
		tag ResultTag
		ok  *interface{}
		err *string
	}{tag: r.tag, ok: nil, err: r.err}
}
func (r ResultIntString) MapErr(fn func(string) interface{}) interface{} {
	if r.tag == ResultTagErr && r.err != nil {
		f := fn(*r.err)
		return struct {
			tag ResultTag
			ok  *int
			err *interface{}
		}{tag: ResultTagErr, ok: nil, err: &f}
	}
	return struct {
		tag ResultTag
		ok  *int
		err *interface{}
	}{tag: r.tag, ok: r.ok, err: nil}
}
func (r ResultIntString) Filter(predicate func(int) bool) ResultIntString {
	if r.tag == ResultTagOk && predicate(*r.ok) {
		return r
	}
	return r
}
func (r ResultIntString) AndThen(fn func(int) interface{}) interface{} {
	if r.tag == ResultTagOk && r.ok != nil {
		return fn(*r.ok)
	}
	return struct {
		tag ResultTag
		ok  *interface{}
		err *string
	}{tag: r.tag, ok: nil, err: r.err}
}
func (r ResultIntString) OrElse(fn func(string) interface{}) interface{} {
	if r.tag == ResultTagErr && r.err != nil {
		return fn(*r.err)
	}
	return struct {
		tag ResultTag
		ok  *int
		err *interface{}
	}{tag: r.tag, ok: r.ok, err: nil}
}
func (r ResultIntString) And(other interface{}) interface{} {
	if r.tag == ResultTagOk {
		return other
	}
	return r
}
func (r ResultIntString) Or(other ResultIntString) ResultIntString {
	if r.tag == ResultTagOk {
		return r
	}
	return other
}

