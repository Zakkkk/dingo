package main

import (
	"errors"
	"fmt"
)


type ResultTag uint8

const (
	ResultTagOk ResultTag = iota
	ResultTagErr
)

type Result struct {
	tag ResultTag
	err *error
	ok  *string
}

func ResultOk(arg0 string) Result {
	return Result{tag: ResultTagOk, ok: &arg0}
}
func ResultErr(arg0 error) Result {
	return Result{tag: ResultTagErr, err: &arg0}
}
func (e Result) IsOk() bool {
	return e.tag == ResultTagOk
}
func (e Result) IsErr() bool {
	return e.tag == ResultTagErr
}
func (r Result) Map(fn func(string) string) Result {
	switch r.tag {
	case ResultTagOk:
		if r.ok != nil {
			return ResultOk(fn(*r.ok))
		}
	case ResultTagErr:
		return r
	}
	panic("invalid Result state")
}
func (r Result) AndThen(fn func(string) Result) Result {
	switch r.tag {
	case ResultTagOk:
		if r.ok != nil {
			return fn(*r.ok)
		}
	case ResultTagErr:
		return r
	}
	panic("invalid Result state")
}


type OptionTag uint8

const (
	OptionTagSome OptionTag = iota
	OptionTagNone
)

type Option struct {
	tag  OptionTag
	some *int
}
func OptionSome(arg0 int) Option {
	return Option{tag: OptionTagSome, some: &arg0}
}
func OptionNone() Option {
	return Option{tag: OptionTagNone}
}
func (e Option) IsSome() bool {
	return e.tag == OptionTagSome
}
func (e Option) IsNone() bool {
	return e.tag == OptionTagNone
}
func (o Option) Map(fn func(int) int) Option {
	switch o.tag {
	case OptionTagSome:
		if o.some != nil {
			return OptionSome(fn(*o.some))
		}
	case OptionTagNone:
		return o
	}
	panic("invalid Option state")
}
func (o Option) AndThen(fn func(int) Option) Option {
	switch o.tag {
	case OptionTagSome:
		if o.some != nil {
			return fn(*o.some)
		}
	case OptionTagNone:
		return o
	}
	panic("invalid Option state")
}
func (o Option) Unwrap() int {
	if o.tag != OptionTagSome {
		panic("called Unwrap on None")
	}
	return *o.some
}
func FindUser(id int) Result {
	if id > 0 {
		return ResultOk(fmt.Sprintf("User%d", id))
	}
	return ResultErr(errors.New("user not found"))
}
func GetCount(id int) Option {
	if id > 0 {
		return OptionSome(id * 10)
	}
	return OptionNone()
}

// Test explicit |err| binding
func TestExplicitErrBinding(id int) Result {
	tmp := FindUser(id)

	if tmp.IsErr() {
		err := *tmp.err
		return ResultErr(err)
	}
	user := *tmp.ok
	return ResultOk(user)
}

// Test custom |e| binding
func TestCustomBinding(id int) Result {
	tmp1 := FindUser(id)

	if tmp1.IsErr() {
		e := *tmp1.err
		fmt.Printf("Custom error: %v\n", e)
		return ResultErr(fmt.Errorf("wrapped: %w", e))
	}
	user := *tmp1.ok
	return ResultOk(user)
}

// Test no binding with Result (but not using err)
func TestNoBindingResult(id int) string {
	tmp2 := FindUser(id)

	if tmp2.IsErr() {
		return "failed"
	}
	user := *tmp2.ok
	return user
}

// Test no binding with Option
func TestNoBindingOption(id int) string {
	tmp3 := GetCount(id)

	if tmp3.IsNone() {
		return "no count"
	}
	count := *tmp3.some
	return fmt.Sprintf("Count: %d", count)
}

// Test complex else body with custom binding name
func TestComplexElseBody(id int) Result {
	tmp4 := FindUser(id)

	if tmp4.IsErr() {
		failure := *tmp4.err
		fmt.Printf("Operation failed with: %v\n", failure)
		if id < 0 {
			return ResultErr(fmt.Errorf("negative id: %w", failure))
		}
		return ResultErr(fmt.Errorf("zero id: %w", failure))
	}
	user := *tmp4.ok

	tmp5 := GetCount(id)

	if tmp5.IsNone() {
		return ResultErr(errors.New("count not available"))
	}
	count := *tmp5.some

	return ResultOk(fmt.Sprintf("%s has count %d", user, count))
}

// Test multiple bindings with different names
func TestMultipleBindings(id1 int, id2 int) string {
	tmp6 := FindUser(id1)

	if tmp6.IsErr() {
		err1 := *tmp6.err
		fmt.Printf("First error: %v\n", err1)
		return "first failed"
	}
	user1 := *tmp6.ok

	tmp7 := FindUser(id2)

	if tmp7.IsErr() {
		err2 := *tmp7.err
		fmt.Printf("Second error: %v\n", err2)
		return "second failed"
	}
	user2 := *tmp7.ok

	return fmt.Sprintf("Got: %s and %s", user1, user2)
}
func main() {
	result1 := TestExplicitErrBinding(1)
	if result1.IsOk() {
		fmt.Println(*result1.ok)
	}

	result2 := TestCustomBinding(0)
	if result2.IsErr() {
		fmt.Println("Error:", *result2.err)
	}

	result3 := TestNoBindingResult(1)
	fmt.Println(result3)

	result4 := TestNoBindingOption(5)
	fmt.Println(result4)

	result5 := TestComplexElseBody(1)
	if result5.IsOk() {
		fmt.Println(*result5.ok)
	}

	result6 := TestMultipleBindings(1, 2)
	fmt.Println(result6)
}
