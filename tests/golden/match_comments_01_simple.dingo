// P0 Bug Fix: Comments in match arms
// Previously, inline comments after match arms would break parsing
package main

import "fmt"

func processResult(result Result[int, error]) int {
	return match result {
		Ok(value) => value,        // Success case
		Err(e) => 0,               // Error case - return zero
	}
}

func main() {
	result := Ok[int, error](42)
	value := processResult(result)
	fmt.Println(value)
}
