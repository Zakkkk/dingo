// Test: Option[T] with method chaining (Map, AndThen)
// Feature: Option type with functional method chaining
// Complexity: advanced
package main

func getValue(id int) Option[int] {
	if id > 0 {
		return Some(id)
	}
	return None[int]()
}

func processValue(opt Option[int]) Option[int] {
	return opt.
		Map(|x| x * 2).
		AndThen(|x| {
			if x > 10 {
				return Some(x)
			}
			return None[int]()
		})
}

func main() {
	let result = processValue(getValue(10))
	if result.IsSome() {
		println("Result:", result.MustSome())
	} else {
		println("None")
	}
}
