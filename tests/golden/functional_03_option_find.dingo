// Test: Slice find() returning Option[T]
// Feature: Functional utilities with Option type
// Complexity: intermediate
package main

import "fmt"

func main() {
	nums := []int{1, 2, 3, 4, 5}

	// find() returns Option[T]
	let result = nums.find(|x| x > 3)

	if result.IsSome() {
		fmt.Printf("Found: %d\n", result.MustSome())
	} else {
		fmt.Println("Not found")
	}
}
