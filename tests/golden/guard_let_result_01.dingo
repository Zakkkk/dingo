// Test: Guard Let with Result type
// Feature: Basic Result unwrapping with pipe binding
// Complexity: basic
package main

import "errors"

func findUser(id int) Result[string, string] {
	if id > 0 {
		return Ok[string, string]("User123")
	}
	return Err[string, string]("user not found")
}

func readConfig(path string) Result[string, error] {
	if path == "" {
		return Err[string, error](errors.New("empty path"))
	}
	return Ok[string, error]("config data")
}

func processUser(id int) Result[string, string] {
	// Basic guard let with Result type and pipe binding
	guard let user = findUser(id) else |err| {
		return Err[string, string](err)
	}

	return Ok[string, string]("Processed: " + user)
}

func loadAndProcess(id int, configPath string) Result[string, error] {
	// Multiple guard lets with Result types
	guard let config = readConfig(configPath) else |e| {
		return Err[string, error](e)
	}

	// Guard let with type conversion in else block
	guard let user = findUser(id) else |msg| {
		return Err[string, error](errors.New(msg))
	}

	return Ok[string, error](config + " - " + user)
}

func main() {
	let result1 = processUser(1)
	if result1.IsOk() {
		println("Success:", result1.MustOk())
	} else {
		println("Error:", result1.MustErr())
	}

	let result2 = loadAndProcess(2, "/etc/config")
	if result2.IsOk() {
		println("Loaded:", result2.MustOk())
	}
}
