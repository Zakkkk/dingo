package main

import (
	"errors"
	"fmt"
)


type ResultTag uint8

const (
	ResultTagOk ResultTag = iota
	ResultTagErr
)

type Result struct {
	tag ResultTag
	err *error
	ok  *int
}

func ResultOk(arg0 int) Result {
	return Result{tag: ResultTagOk, ok: &arg0}
}
func ResultErr(arg0 error) Result {
	return Result{tag: ResultTagErr, err: &arg0}
}
func (e Result) IsOk() bool {
	return e.tag == ResultTagOk
}
func (e Result) IsErr() bool {
	return e.tag == ResultTagErr
}
func (r Result) Map(fn func(int) int) Result {
	switch r.tag {
	case ResultTagOk:
		if r.ok != nil {
			return ResultOk(fn(*r.ok))
		}
	case ResultTagErr:
		return r
	}
	panic("invalid Result state")
}
func (r Result) AndThen(fn func(int) Result) Result {
	switch r.tag {
	case ResultTagOk:
		if r.ok != nil {
			return fn(*r.ok)
		}
	case ResultTagErr:
		return r
	}
	panic("invalid Result state")
}


type OptionTag uint8

const (
	OptionTagSome OptionTag = iota
	OptionTagNone
)

type Option struct {
	tag  OptionTag
	some *string
}
func OptionSome(arg0 string) Option {
	return Option{tag: OptionTagSome, some: &arg0}
}
func OptionNone() Option {
	return Option{tag: OptionTagNone}
}
func (e Option) IsSome() bool {
	return e.tag == OptionTagSome
}
func (e Option) IsNone() bool {
	return e.tag == OptionTagNone
}
func (o Option) Map(fn func(string) string) Option {
	switch o.tag {
	case OptionTagSome:
		if o.some != nil {
			return OptionSome(fn(*o.some))
		}
	case OptionTagNone:
		return o
	}
	panic("invalid Option state")
}
func (o Option) AndThen(fn func(string) Option) Option {
	switch o.tag {
	case OptionTagSome:
		if o.some != nil {
			return fn(*o.some)
		}
	case OptionTagNone:
		return o
	}
	panic("invalid Option state")
}
func (o Option) Unwrap() string {
	if o.tag != OptionTagSome {
		panic("called Unwrap on None")
	}
	return *o.some
}
func GetValue(id int) Result {
	if id > 0 {
		return ResultOk(id * 10)
	}
	return ResultErr(errors.New("invalid id"))
}
func GetName(id int) Option {
	if id > 0 {
		return OptionSome(fmt.Sprintf("Item%d", id))
	}
	return OptionNone()
}

// Single-line guard let with Result
func ProcessValue(id int) Result {
	tmp := GetValue(id)

	if tmp.IsErr() {
		err := *tmp.err
		return ResultErr(err)
	}
	val := *tmp.ok
	return ResultOk(val + 100)
}

// Single-line guard let with Option
func ProcessName(id int) string {
	tmp1 := GetName(id)

	if tmp1.IsNone() {
		return "unknown"
	}
	name := *tmp1.some
	return fmt.Sprintf("Name: %s", name)
}

// Mix of Result and Option inline
func ProcessBoth(id int) string {
	tmp2 := GetValue(id)

	if tmp2.IsErr() {
		err := *tmp2.err
		_ = err
		return "value error"
	}
	val := *tmp2.ok
	tmp3 := GetName(id)

	if tmp3.IsNone() {
		return "name not found"
	}
	name := *tmp3.some
	return fmt.Sprintf("%s = %d", name, val)
}

// Multiple inline guards
func ChainedGuards(id1 int, id2 int, id3 int) Result {
	tmp4 := GetValue(id1)

	if tmp4.IsErr() {
		err := *tmp4.err
		return ResultErr(err)
	}
	v1 := *tmp4.ok
	tmp5 := GetValue(id2)

	if tmp5.IsErr() {
		err := *tmp5.err
		return ResultErr(err)
	}
	v2 := *tmp5.ok
	tmp6 := GetValue(id3)

	if tmp6.IsErr() {
		err := *tmp6.err
		return ResultErr(err)
	}
	v3 := *tmp6.ok
	return ResultOk(v1 + v2 + v3)
}
func main() {
	result1 := ProcessValue(5)
	if result1.IsOk() {
		fmt.Println("Value:", *result1.ok)
	}

	result2 := ProcessName(10)
	fmt.Println(result2)

	result3 := ProcessBoth(3)
	fmt.Println(result3)

	result4 := ChainedGuards(1, 2, 3)
	if result4.IsOk() {
		fmt.Println("Sum:", *result4.ok)
	}
}
