package main

// Test: Guard Let with Option type
// Feature: Basic Option unwrapping without pipe binding
// Complexity: basic

func findSetting(key string) Option<string> {
	if key == "theme" {
		return Some("dark")
	}
	return Option_string_None()
}

func getAge(name string) Option<int> {
	if name == "Alice" {
		return Some(30)
	}
	return Option_int_None()
}

func loadTheme() Option<string> {
	// Basic guard let with Option type (no pipe binding)
	guard let theme = findSetting("theme") else {
		return Option_string_None()
	}

	return Some("Applied theme: " + theme)
}

func getUserInfo(name string) Option<string> {
	// Multiple guard lets with Option types
	guard let setting = findSetting("theme") else {
		return Option_string_None()
	}

	guard let age = getAge(name) else {
		return Option_string_None()
	}

	// Convert int to string (simplified)
	let ageStr = "30"
	return Some(setting + " user age: " + ageStr)
}

func main() {
	let result1 = loadTheme()
	if result1.IsSome() {
		println("Theme:", result1.Unwrap())
	} else {
		println("No theme found")
	}

	let result2 = getUserInfo("Alice")
	if result2.IsSome() {
		println("Info:", result2.Unwrap())
	}
}
