package main

// Test: Basic pattern guards with 'if' keyword
// Feature: Pattern matching with runtime guard conditions
// Complexity: basic

type Result interface {
	isResult()
	IsOk() bool
	IsErr() bool
}

type ResultOk struct{ Value int }

func (ResultOk) isResult()         {}
func NewResultOk(value int) Result { return ResultOk{Value: value} }

type ResultErr struct{ Value error }

func (ResultErr) isResult()           {}
func NewResultErr(value error) Result { return ResultErr{Value: value} }

func IsResultOk(v Result) bool  { _, ok := v.(ResultOk); return ok }
func IsResultErr(v Result) bool { _, ok := v.(ResultErr); return ok }
func (ResultOk) IsOk() bool     { return true }
func (ResultOk) IsErr() bool    { return false }
func (ResultErr) IsOk() bool    { return false }
func (ResultErr) IsErr() bool   { return true }

// Simple guard on Result type
func classifyNumber(result Result) string {
	return func() string {
		switch v := result.(type) {
		case ResultOk:
			x := v.x
			if x > 0 {
				return "positive"
			}
			panic("match guard failed without fallback")
		case ResultOk:
			x := v.x
			if x < 0 {
				return "negative"
			}
			panic("match guard failed without fallback")
		case ResultOk:
			return "zero"
		case ResultErr:
			e := v.e
			return "error"
		}
	}()
}

// Guard with multiple conditions
func validateAge(result Result) string {
	return func() string {
		switch v := result.(type) {
		case ResultOk:
			age := v.age
			if age >= 18 && age < 65 {
				return "adult"
			}
			panic("match guard failed without fallback")
		case ResultOk:
			age := v.age
			if age >= 65 {
				return "senior"
			}
			panic("match guard failed without fallback")
		case ResultOk:
			return "minor"
		case ResultErr:
			return "invalid"
		}
	}()
}

// Guard with function call
func checkLength(result Result) string {
	return func() string {
		switch v := result.(type) {
		case ResultOk:
			n := v.n
			if isEven(n) {
				return "even"
			}
			panic("match guard failed without fallback")
		case ResultOk:
			return "odd"
		case ResultErr:
			return "error"
		}
	}()
}

func isEven(n int) bool {
	return n%2 == 0
}

func main() {
	println(classifyNumber(ResultOk(42)))
	println(validateAge(ResultOk(25)))
	println(checkLength(ResultOk(10)))
}
