package main

// Test: Basic pattern guards with 'if' keyword
// Feature: Pattern matching with runtime guard conditions
// Complexity: basic


type ResultTag uint8

const (
	ResultTagOk ResultTag = iota
	ResultTagErr
)

type Result struct {
	tag ResultTag
	err *error
	ok  *int
}

func ResultOk(arg0 int) Result {
	return Result{tag: ResultTagOk, ok: &arg0}
}
func ResultErr(arg0 error) Result {
	return Result{tag: ResultTagErr, err: &arg0}
}
func (e Result) IsOk() bool {
	return e.tag == ResultTagOk
}
func (e Result) IsErr() bool {
	return e.tag == ResultTagErr
}
func (r Result) Map(fn func(int) int) Result {
	switch r.tag {
	case ResultTagOk:
		if r.ok != nil {
			return ResultOk(fn(*r.ok))
		}
	case ResultTagErr:
		return r
	}
	panic("invalid Result state")
}
func (r Result) AndThen(fn func(int) Result) Result {
	switch r.tag {
	case ResultTagOk:
		if r.ok != nil {
			return fn(*r.ok)
		}
	case ResultTagErr:
		return r
	}
	panic("invalid Result state")
}

// Simple guard on Result type
func classifyNumber(result Result) string {
	var matchResult string
	// DINGO_MATCH_START: result
	scrutinee := result
	switch scrutinee.tag {
	case ResultOkTag:
		// DINGO_PATTERN: ResultOk(x)
		if !(x > 0) {
			break // Guard failed
		}
		x := scrutinee.X
		matchResult = "positive"
	case ResultOkTag:
		// DINGO_PATTERN: ResultOk(x)
		if !(x < 0) {
			break // Guard failed
		}
		x := scrutinee.X
		matchResult = "negative"
	case ResultOkTag:
		// DINGO_PATTERN: ResultOk(_)
		_ := scrutinee._
		matchResult = "zero"
	case ResultErrTag:
		// DINGO_PATTERN: ResultErr(e)
		e := scrutinee.E
		matchResult = "error"
	}
	return matchResult
	// DINGO_MATCH_END

}

// Guard with multiple conditions
func validateAge(result Result) string {
	var matchResult1 string
	// DINGO_MATCH_START: result
	scrutinee := result
	switch scrutinee.tag {
	case ResultOkTag:
		// DINGO_PATTERN: ResultOk(age)
		if !(age >= 18 && age < 65) {
			break // Guard failed
		}
		age := scrutinee.Age
		matchResult1 = "adult"
	case ResultOkTag:
		// DINGO_PATTERN: ResultOk(age)
		if !(age >= 65) {
			break // Guard failed
		}
		age := scrutinee.Age
		matchResult1 = "senior"
	case ResultOkTag:
		// DINGO_PATTERN: ResultOk(_)
		_ := scrutinee._
		matchResult1 = "minor"
	case ResultErrTag:
		// DINGO_PATTERN: ResultErr(_)
		_ := scrutinee._
		matchResult1 = "invalid"
	}
	return matchResult1
	// DINGO_MATCH_END

}

// Guard with function call
func checkLength(result Result) string {
	var matchResult2 string
	// DINGO_MATCH_START: result
	scrutinee := result
	switch scrutinee.tag {
	case ResultOkTag:
		// DINGO_PATTERN: ResultOk(n)
		if !(isEven(n)) {
			break // Guard failed
		}
		n := scrutinee.N
		matchResult2 = "even"
	case ResultOkTag:
		// DINGO_PATTERN: ResultOk(_)
		_ := scrutinee._
		matchResult2 = "odd"
	case ResultErrTag:
		// DINGO_PATTERN: ResultErr(_)
		_ := scrutinee._
		matchResult2 = "error"
	}
	return matchResult2
	// DINGO_MATCH_END

}
func isEven(n int) bool {
	return n%2 == 0
}
func main() {
	println(classifyNumber(ResultOk(42)))
	println(validateAge(ResultOk(25)))
	println(checkLength(ResultOk(10)))
}
