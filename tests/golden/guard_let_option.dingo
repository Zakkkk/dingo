package main

import "fmt"

enum Option {
	Some(string),
	None,
}

func FindUserByEmail(email string) Option {
	if email != "" {
		return OptionSome("User_" + email)
	}
	return OptionNone()
}

func GetPreference(userID int) Option {
	if userID > 0 {
		return OptionSome("dark_mode")
	}
	return OptionNone()
}

// Basic guard let with Option (no err binding)
func ProcessUser(maybeUser Option) string {
	guard let user = maybeUser else {
		return "no user"
	}
	return fmt.Sprintf("Processing: %s", user)
}

// Multiple guard lets with Option
func GetUserSettings(email string, userID int) string {
	guard let user = FindUserByEmail(email) else {
		return "User not found"
	}

	guard let pref = GetPreference(userID) else {
		return "No preferences"
	}

	return fmt.Sprintf("%s prefers %s", user, pref)
}

// Different return types with Option
func ValidateUser(maybeUser Option) (string, bool) {
	guard let user = maybeUser else {
		return "", false
	}
	return user, true
}

func main() {
	result1 := ProcessUser(OptionSome("Alice"))
	fmt.Println(result1)

	result2 := ProcessUser(OptionNone())
	fmt.Println(result2)

	result3 := GetUserSettings("alice@example.com", 1)
	fmt.Println(result3)

	user, ok := ValidateUser(OptionSome("Bob"))
	if ok {
		fmt.Printf("Valid user: %s\n", user)
	}
}
