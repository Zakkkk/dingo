package main

import (
	"database/sql"
	"github.com/MadAppGang/dingo/pkg/dgo"
)

// Custom error type with method call pattern
type ServiceError struct {
	Code    string
	Message string
}

func (e ServiceError) Error() string {
	return e.Code + ": " + e.Message
}

// Constructor method
func (ServiceError) NewDBError(err error) ServiceError {
	return ServiceError{Code: "DB_ERROR", Message: err.Error()}
}

// Test Type.Method(err) pattern
func FindUsers(db *sql.DB) dgo.Result[[]string, ServiceError] {
	tmp, err := db.Query("SELECT * FROM users")

	if err != nil {
		return ResultSliceStringServiceErrorErr(ServiceError.NewDBError(err))
	}
	var rows = tmp
	defer rows.Close()
	return ResultSliceStringServiceErrorOk([]string{"user1", "user2"})
}
func main() {
	var db *sql.DB = nil
	result := FindUsers(db)
	if result.IsErr() {
		println("Error:", result.err.Error())
	}
}
