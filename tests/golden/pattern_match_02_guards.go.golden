package main

// Test: Pattern matching with guards
// Feature: Match with conditional guards
// Complexity: intermediate


type ValueTag uint8

const (
	ValueTagInt ValueTag = iota
	ValueTagString
)

type Value struct {
	tag    ValueTag
	int    *int
	string *string
}

func ValueInt(arg0 int) Value {
	return Value{tag: ValueTagInt, int: &arg0}
}
func ValueString(arg0 string) Value {
	return Value{tag: ValueTagString, string: &arg0}
}
func (e Value) IsInt() bool {
	return e.tag == ValueTagInt
}
func (e Value) IsString() bool {
	return e.tag == ValueTagString
}
func describe(v Value) string {
	tmp := v
	switch tmp.tag {
	case ValueTagInt:
		n := *tmp.value_int_n
		if n > 0 {
			return "Positive number" // dingo:M:1
		} else if n < 0 {
			return "Negative number" // dingo:M:1
		} else {
			return "Zero" // dingo:M:1
		}
	case ValueTagString:
		s := *tmp.value_string_s
		if len(s) > 5 {
			return "Long string" // dingo:M:1
		} else {
			return "Short string" // dingo:M:1
		}
	}
	panic("non-exhaustive match")

}
func main() {
	val1 := ValueInt(42)
	val2 := ValueString("hello world")

	println(describe(val1))
	println(describe(val2))
}
