package main

// Test: Pattern matching with guards
// Feature: Match with conditional guards
// Complexity: intermediate


type ValueTag uint8

const (
	ValueTagInt ValueTag = iota
	ValueTagString
)

type Value struct {
	tag    ValueTag
	int    *int
	string *string
}

func ValueInt(arg0 int) Value {
	return Value{tag: ValueTagInt, int: &arg0}
}
func ValueString(arg0 string) Value {
	return Value{tag: ValueTagString, string: &arg0}
}
func (e Value) IsInt() bool {
	return e.tag == ValueTagInt
}
func (e Value) IsString() bool {
	return e.tag == ValueTagString
}
func describe(v Value) string {
	var __match_result_0 string
	// DINGO_MATCH_START: v
	scrutinee := v
	switch scrutinee.tag {
	case ValueTagInt:
		n := *scrutinee.int
		// DINGO_PATTERN: ValueInt(n) | DINGO_GUARD: n > 0
		if n > 0 {
			__match_result_0 = "Positive number"
			// DINGO_PATTERN: ValueInt(n) | DINGO_GUARD: n < 0
		} else if n < 0 {
			__match_result_0 = "Negative number"
			// DINGO_PATTERN: ValueInt(_)
		} else {
			__match_result_0 = "Zero"
		}
	case ValueTagString:
		s := *scrutinee.string
		// DINGO_PATTERN: ValueString(s) | DINGO_GUARD: len(s) > 5
		if len(s) > 5 {
			__match_result_0 = "Long string"
			// DINGO_PATTERN: ValueString(_)
		} else {
			__match_result_0 = "Short string"
		}
	}
	return __match_result_0
	// DINGO_MATCH_END

}
func main() {
	val1 := ValueInt(42)
	val2 := ValueString("hello world")

	println(describe(val1))
	println(describe(val2))
}
