package main

// Test: Pattern matching with guards
// Feature: Match with conditional guards
// Complexity: intermediate


type ValueTag uint8

const (
	ValueTagInt ValueTag = iota
	ValueTagString
)

type Value struct {
	tag    ValueTag
	int    *int
	string *string
}

func ValueInt(arg0 int) Value {
	return Value{tag: ValueTagInt, int: &arg0}
}
func ValueString(arg0 string) Value {
	return Value{tag: ValueTagString, string: &arg0}
}
func (e Value) IsInt() bool {
	return e.tag == ValueTagInt
}
func (e Value) IsString() bool {
	return e.tag == ValueTagString
}
func describe(v Value) string {
	var matchResult string
	// DINGO_MATCH_START: v
	scrutinee := v
	switch scrutinee.tag {
	case ValueTagInt:
		// DINGO_PATTERN: ValueInt(n)
		if !(n > 0) {
			break // Guard failed
		}
		n := scrutinee.N
		matchResult = "Positive number"
	case ValueTagInt:
		// DINGO_PATTERN: ValueInt(n)
		if !(n < 0) {
			break // Guard failed
		}
		n := scrutinee.N
		matchResult = "Negative number"
	case ValueTagInt:
		// DINGO_PATTERN: ValueInt(_)
		_ := scrutinee._
		matchResult = "Zero"
	case ValueTagString:
		// DINGO_PATTERN: ValueString(s)
		if !(len(s) > 5) {
			break // Guard failed
		}
		s := scrutinee.S
		matchResult = "Long string"
	case ValueTagString:
		// DINGO_PATTERN: ValueString(_)
		_ := scrutinee._
		matchResult = "Short string"
	}
	return matchResult
	// DINGO_MATCH_END

}
func main() {
	val1 := ValueInt(42)
	val2 := ValueString("hello world")

	println(describe(val1))
	println(describe(val2))
}
