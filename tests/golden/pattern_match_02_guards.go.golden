package main

// Test: Pattern matching with guards
// Feature: Match with conditional guards
// Complexity: intermediate

type Value interface {
	isValue()
	IsInt() bool
	IsString() bool
}

type ValueInt struct{ Value int }

func (ValueInt) isValue()         {}
func NewValueInt(value int) Value { return ValueInt{Value: value} }

type ValueString struct{ Value string }

func (ValueString) isValue()            {}
func NewValueString(value string) Value { return ValueString{Value: value} }

func IsValueInt(v Value) bool      { _, ok := v.(ValueInt); return ok }
func IsValueString(v Value) bool   { _, ok := v.(ValueString); return ok }
func (ValueInt) IsInt() bool       { return true }
func (ValueInt) IsString() bool    { return false }
func (ValueString) IsInt() bool    { return false }
func (ValueString) IsString() bool { return true }

func describe(v Value) string {
	return func() string {
		switch v := v.(type) {
		case Value_Int:
			n := v.n
			if n > 0 {
				return "Positive number"
			}
			panic("match guard failed without fallback")
		case Value_Int:
			n := v.n
			if n < 0 {
				return "Negative number"
			}
			panic("match guard failed without fallback")
		case Value_Int:
			return "Zero"
		case Value_String:
			s := v.s
			if len(s) > 5 {
				return "Long string"
			}
			panic("match guard failed without fallback")
		case Value_String:
			return "Short string"
		}
	}()
}

func main() {
	val1 := Value_Int(42)
	val2 := Value_String("hello world")

	println(describe(val1))
	println(describe(val2))
}
