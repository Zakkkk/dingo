package main

import "fmt"

// Test: Error propagation with Rust-style lambda transform
// Feature: error-propagation
// Complexity: intermediate

// This test demonstrates the ? |err| transform syntax for
// custom error transformation using Rust-style lambdas.

type AppError struct {
	Context string
	Cause   error
}

func (e AppError) Error() string {
	return fmt.Sprintf("%s: %v", e.Context, e.Cause)
}

func wrap(ctx string, err error) error {
	return AppError{Context: ctx, Cause err}
}

func loadUserData(userID int) (UserData, error) {
	let user = fetchUser(userID) ? |err| wrap("user fetch", err)
	let posts = fetchPosts(user.ID) ? |e| wrap("posts fetch", e)
	return UserData{User: user, Posts posts}, nil
}

type User struct {
	ID   int
	Name string
}

type Post struct {
	Title string
}

type UserData struct {
	User  User
	Posts []Post
}

func fetchUser(id int) (User, error) {
	return User{ID: id, Name: "Test"}, nil
}

func fetchPosts(userID int) ([]Post, error) {
	return []Post{{Title: "Hello"}}, nil
}
