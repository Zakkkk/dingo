// Test: Result[T, E] interoperating with Go (T, error) functions
// Feature: Result type + Go interop patterns
// Complexity: intermediate
package main

import (
	"errors"
	"strconv"
)

func convertToInt(s string) Result[int, error] {
	// Calling Go stdlib function that returns (int, error)
	val, err := strconv.Atoi(s)
	if err != nil {
		return Err[int, error](err)
	}
	return Ok[int, error](val)
}

func doubleIfValid(s string) (int, error) {
	let result = convertToInt(s)
	if result.IsErr() {
		return 0, result.MustErr()
	}
	return result.MustOk() * 2, nil
}

func main() {
	val, err := doubleIfValid("42")
	if err == nil {
		println("Doubled:", val)
	}
}
