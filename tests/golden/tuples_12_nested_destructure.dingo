package main

// Test: Nested tuple destructuring patterns
// Feature: let ((a, b), c) = expr destructuring
// Complexity: advanced

func getNestedData() ((int, int), int) {
	return ((10, 20), 30)
}

func getDeepData() (((int, int), int), int) {
	return (((1, 2), 3), 4)
}

func getMixedData() ((string, int), (bool, float64)) {
	return (("Alice", 25), (true, 98.6))
}

func main() {
	// Basic nested destructuring: ((a, b), c)
	let ((x1, y1), z1) = getNestedData()
	println("Basic nested:", x1, y1, z1)

	// Destructure nested tuple literal
	let ((a, b), c) = ((100, 200), 300)
	println("From literal:", a, b, c)

	// Deep nesting: (((a, b), c), d)
	let (((p, q), r), s) = getDeepData()
	println("Deep nested:", p, q, r, s)

	// Mixed types in nested destructuring
	let ((name, age), (active, temp)) = getMixedData()
	println("Mixed:", name, age, active, temp)

	// Nested destructuring with wildcards
	let ((first, _), last) = ((1, 2), 3)
	println("With wildcards:", first, last)

	// Wildcard the entire inner tuple
	let (_, outer) = ((10, 20), 30)
	println("Outer only:", outer)

	// Multiple nested destructures
	let data1 = ((5, 6), 7)
	let data2 = ((8, 9), 10)
	let ((v1, v2), v3) = data1
	let ((v4, v5), v6) = data2
	println("Multiple:", v1, v2, v3, v4, v5, v6)

	// Asymmetric nesting: ((a, b, c), d)
	let ((i, j, k), l) = ((11, 12, 13), 14)
	println("Asymmetric:", i, j, k, l)

	// Nested destructuring in pattern: (a, (b, c))
	// This tests nesting in the second position
	let result = getReversedNested()
	let (outer1, (inner1, inner2)) = result
	println("Reversed nesting:", outer1, inner1, inner2)

	// Very deep nesting (3 levels)
	let ((((w, x), y), z)) = ((((15, 16), 17), 18))
	println("Very deep:", w, x, y, z)

	// Edge case: all wildcards except one
	let ((target, _), _) = ((99, 88), 77)
	println("Target only:", target)
}

func getReversedNested() (int, (int, int)) {
	return (40, (50, 60))
}
