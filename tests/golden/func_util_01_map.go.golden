package main

// Test: Map function on slices
// Feature: Functional map utility
// Complexity: basic

func mapSlice(arr []int, f func(int) int) []int {
	result := make([]int, len(arr))
	for i, v := range arr {
		result[i] = f(v)
	}
	return result
}
func main() {
	numbers := []int{1, 2, 3, 4, 5}

	// Map with lambda
	doubled := mapSlice(numbers, func(x __TYPE_INFERENCE_NEEDED) { return x * 2 })
	squared := mapSlice(numbers, func(x __TYPE_INFERENCE_NEEDED) { return x * x })

	println("Doubled:", doubled)
	println("Squared:", squared)
}
