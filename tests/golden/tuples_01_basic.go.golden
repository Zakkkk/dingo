package main

// Test: Basic tuple usage
// Feature: Tuples for multiple return values
// Complexity: basic

func divMod(a int, b int) (int, int) {
	return a / b, a % b
}
func getCoordinates() (int, int, int) {
	return 10, 20, 30
}
func main() {
	// Tuple destructuring
	tmp := divMod(17, 5)
	quotient, remainder := tmp._0, tmp._1
	tmp1 := getCoordinates()
	x, y, z := tmp1._0, tmp1._1, tmp1._2

	println("Quotient:", quotient, "Remainder:", remainder)
	println("Coords:", x, y, z)
}
