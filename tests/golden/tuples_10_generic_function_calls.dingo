package main

// Test: Generic function calls should NOT be treated as tuples
// Feature: Tuple vs generic function call disambiguation
// Complexity: intermediate

type User struct {
	Name string
	Age  int
}

func getUserOptional() Option[User] {
	return None[User]()
}

func getNumber() Option[int] {
	return Some[int](42)
}

func readFile() Result[string, error] {
	return Err[string, error]("file not found")
}

func makeMap() map[string]int {
	return make(map[string]int)
}

func main() {
	// None[T]() is a generic function call, NOT an empty tuple
	let maybeUser = None[User]()
	println("User option:", maybeUser)

	// Some[T](value) is a generic function call with one argument
	let num = Some[int](42)
	println("Number:", num)

	// Result[T,E](value) is a generic function call
	let result = Err[string, error]("error message")
	println("Result:", result)

	// make() with type parameters
	let m = make(map[string]int)
	println("Map:", m)

	// Multiple generic calls in one line
	let opt1 = None[string]()
	let opt2 = Some[bool](true)
	println("Options:", opt1, opt2)

	// Generic calls in if condition
	if getUserOptional() == None[User]() {
		println("No user found")
	}

	// Actual tuples should still work
	let coords = (10, 20)
	let (x, y) = coords
	println("Coords:", x, y)

	// Generic call followed by tuple
	let option = Some[int](100)
	let pair = (200, 300)
	println("Option and pair:", option, pair)
}
