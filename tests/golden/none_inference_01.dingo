package main

import (
	"fmt"
)

// Test struct with Option fields
type UserSettings struct {
	Theme    string
	Language Option[string] // Will be set to None
	FontSize Option[int]    // Will be set to None()
}

// Test return statement inference
func getDefaultLanguage() Option[string] {
	return None
}

// Test generic function return inference
func GetEmpty[T any]() Option[T] {
	return None
}

// Test function argument inference
func processLanguage(lang Option[string]) string {
	return lang.SomeOr("en")
}

// Test assignment in conditional
func getOptionalValue(hasValue bool) Option[int] {
	var result Option[int]
	if hasValue {
		result = Some(42)
	} else {
		result = None
	}
	return result
}

func main() {
	// Struct field inference - identifier form
	settings1 := UserSettings{
		Theme:    "dark",
		Language None, // Infer from field type (Option[string])
		FontSize: Some(14),
	}

	// Struct field inference - call form
	settings2 := UserSettings{
		Theme:    "light",
		Language: Some("es"),
		FontSize: None(), // Infer from field type (Option[int])
	}

	// Mixed None and Some
	settings3 := UserSettings{
		Theme:    "auto",
		Language None,
		FontSize None,
	}

	// Variable declaration inference
	var lang Option[string] = None

	// Assignment inference after declaration
	lang = None

	// Function argument inference
	result := processLanguage(None)

	// Return value inference (via getDefaultLanguage)
	defaultLang := getDefaultLanguage()

	// Generic function return inference
	emptyInt := GetEmpty[int]()
	emptyString := GetEmpty[string]()

	// Conditional assignment inference
	value := getOptionalValue(false)

	// Array/slice with None elements
	options := []Option[string]{
		Some("value1"),
		None,
		Some("value3"),
		None(),
	}

	// Map with None values
	config := map[string]Option[int]{
		"timeout":   Some(30),
		"maxRetries": None,
		"bufferSize": None(),
	}

	// Print all results
	fmt.Println(settings1, settings2, settings3)
	fmt.Println(lang, result, defaultLang)
	fmt.Println(emptyInt, emptyString, value)
	fmt.Println(options, config)
}
