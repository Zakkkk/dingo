{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-forbidden-patterns.sh"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    },
    "mag-claude-plugins": {
      "source": {
        "source": "github",
        "repo": "MadAppGang/claude-code"
      }
    }
  },
  "enabledPlugins": {
    "orchestration@mag-claude-plugins": true,
    "code-analysis@mag-claude-plugins": true,
    "commit-commands@claude-code-plugins": true,
    "explanatory-output-style@claude-code-plugins": true,
    "feature-dev@claude-code-plugins": true,
    "learning-output-style@claude-code-plugins": true,
    "ralph-wiggum@claude-code-plugins": true
  },
  "installedPluginVersions": {
    "orchestration@mag-claude-plugins": "0.5.0",
    "code-analysis@mag-claude-plugins": "2.3.0",
    "commit-commands@claude-code-plugins": "1.0.0",
    "explanatory-output-style@claude-code-plugins": "1.0.0",
    "feature-dev@claude-code-plugins": "1.0.0",
    "learning-output-style@claude-code-plugins": "1.0.0",
    "ralph-wiggum@claude-code-plugins": "1.0.0"
  }
}
