{
  "name": "dingo",
  "displayName": "Dingo Language Support",
  "description": "Syntax highlighting and language support for Dingo - a modern meta-language for Go",
  "version": "0.3.0",
  "publisher": "MadAppGang",
  "icon": "dingo-logo.png",
  "homepage": "https://dingolang.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/MadAppGang/dingo"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Themes"
  ],
  "keywords": [
    "dingo",
    "go",
    "golang",
    "result",
    "option",
    "error-handling",
    "syntax-highlighting",
    "transpiler",
    "meta-language",
    "type-safety"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:dingo",
    "onLanguage:go"
  ],
  "contributes": {
    "iconThemes": [
      {
        "id": "dingo-icons",
        "label": "Dingo Icons",
        "path": "./icons/dingo-icons.json"
      }
    ],
    "languages": [
      {
        "id": "dingo",
        "aliases": [
          "Dingo",
          "dingo"
        ],
        "extensions": [
          ".dingo"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/dingo.svg",
          "dark": "./icons/dingo.svg"
        }
      }
    ],
    "configurationDefaults": {
      "files.associations": {
        "*.go.golden": "go",
        "*.dingo": "dingo"
      },
      "[dingo]": {
        "editor.quickSuggestions": {
          "other": true,
          "comments": false,
          "strings": false
        },
        "editor.suggest.snippetsPreventQuickSuggestions": false,
        "editor.wordBasedSuggestions": false,
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "dingo.dingo"
      }
    },
    "grammars": [
      {
        "language": "dingo",
        "scopeName": "source.dingo",
        "path": "./syntaxes/dingo.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Dingo",
      "properties": {
        "dingo.lsp.path": {
          "type": "string",
          "default": "dingo-lsp",
          "description": "Path to dingo-lsp binary (default: searches $PATH)"
        },
        "dingo.transpileOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically transpile .dingo files on save"
        },
        "dingo.lsp.logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "default": "info",
          "description": "LSP server log level"
        },
        "dingo.lsp.sqliteLogging": {
          "type": "boolean",
          "default": false,
          "description": "Enable SQLite structured logging for debugging (creates database file)"
        },
        "dingo.lsp.sqliteLogPath": {
          "type": "string",
          "default": "/tmp/dingo-lsp.db",
          "markdownDescription": "Path to SQLite log database"
        }
      }
    },
    "commands": [
      {
        "command": "dingo.transpileCurrentFile",
        "title": "Dingo: Transpile Current File"
      },
      {
        "command": "dingo.transpileWorkspace",
        "title": "Dingo: Transpile All Files in Workspace"
      },
      {
        "command": "dingo.restartLSP",
        "title": "Dingo: Restart Language Server"
      },
      {
        "command": "dingo.compareWithSource",
        "title": "Dingo: Compare with Source File",
        "icon": "$(diff)"
      },
      {
        "command": "dingo.buildCurrentFile",
        "title": "Dingo: Build Current File",
        "icon": "$(tools)"
      },
      {
        "command": "dingo.runCurrentFile",
        "title": "Dingo: Run Current File",
        "icon": "$(play)"
      },
      {
        "command": "dingo.buildWorkspace",
        "title": "Dingo: Build Workspace",
        "icon": "$(package)"
      },
      {
        "command": "dingo.generateDebugConfig",
        "title": "Dingo: Generate Debug Configuration"
      }
    ],
    "taskDefinitions": [
      {
        "type": "dingo",
        "required": ["command"],
        "properties": {
          "command": {
            "type": "string",
            "description": "The dingo command to run (build, run, go)",
            "enum": ["build", "run", "go"]
          },
          "target": {
            "type": "string",
            "description": "File or directory to build/run"
          },
          "args": {
            "type": "array",
            "description": "Additional arguments to pass to dingo",
            "items": {
              "type": "string"
            }
          }
        }
      }
    ],
    "debuggers": [
      {
        "type": "dingo",
        "label": "Dingo",
        "languages": ["dingo"],
        "configurationAttributes": {
          "launch": {
            "required": ["program"],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to .dingo file to debug",
                "default": "${file}"
              },
              "args": {
                "type": "array",
                "description": "Command line arguments passed to the program",
                "items": { "type": "string" },
                "default": []
              },
              "cwd": {
                "type": "string",
                "description": "Working directory for the program",
                "default": "${workspaceFolder}"
              },
              "env": {
                "type": "object",
                "description": "Environment variables",
                "default": {}
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "dingo",
            "request": "launch",
            "name": "Debug Dingo File",
            "program": "${file}"
          }
        ],
        "configurationSnippets": [
          {
            "label": "Dingo: Debug File",
            "description": "Build and debug a .dingo file",
            "body": {
              "type": "dingo",
              "request": "launch",
              "name": "Debug Dingo File",
              "program": "^\"\\${file}\""
            }
          },
          {
            "label": "Dingo: Debug Package",
            "description": "Build and debug a Dingo package",
            "body": {
              "type": "dingo",
              "request": "launch",
              "name": "Debug Dingo Package",
              "program": "^\"\\${workspaceFolder}\""
            }
          }
        ]
      }
    ],
    "problemMatchers": [
      {
        "name": "dingo",
        "owner": "dingo",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": [
          {
            "regexp": "^(.+):(\\d+):(\\d+):\\s+(error|warning):\\s+(.+)$",
            "file": 1,
            "line": 2,
            "column": 3,
            "severity": 4,
            "message": 5
          }
        ]
      },
      {
        "name": "dingo-go",
        "owner": "dingo",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": [
          {
            "regexp": "^(.+\\.go):(\\d+):(\\d+):\\s+(.+)$",
            "file": 1,
            "line": 2,
            "column": 3,
            "message": 4
          }
        ]
      }
    ],
    "keybindings": [
      {
        "command": "dingo.compareWithSource",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "when": "resourceExtname == .dingo || resourceExtname == .golden"
      },
      {
        "command": "dingo.buildCurrentFile",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b",
        "when": "resourceExtname == .dingo"
      },
      {
        "command": "dingo.runCurrentFile",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "resourceExtname == .dingo"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build-grammar": "node scripts/build-grammar.js",
    "package": "vsce package",
    "publish": "vsce publish",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^2.22.0",
    "glob": "^10.3.10",
    "js-yaml": "^4.1.0",
    "mocha": "^10.2.0",
    "typescript": "^5.0.0"
  }
}
